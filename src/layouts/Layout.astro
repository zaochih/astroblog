---
import '../styles/global.css';
import { siteConfig, licensePresets, type LicensePreset } from '@/config';
import { useTranslations, languages, languageNames, defaultLang, type Lang } from '@/i18n/ui';

/** Normalise BCP47 tag for HTML: 'zh-cn' → 'zh-CN', 'en-us' → 'en-US' */
function toHtmlLang(tag: string) {
  return tag.replace(/-([a-z]+)$/, (_, r) => '-' + r.toUpperCase());
}
import LanguageToast from '@/components/LanguageToast.astro';
import LanguagePreference from '@/components/LanguagePreference.astro';
import SmartHeader from '@/components/SmartHeader.astro';
import DetailsAnimator from '@/components/DetailsAnimator.astro';
import HugeIcon from '@/components/HugeIcon';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  lang?: string;
  showLangToast?: boolean;
  showLanguageSwitcher?: boolean;
  /** Optional OG image URL (absolute) */
  image?: string;
  canonicalUrl?: string;
  math?: boolean;
  hideHeaderOnScroll?: boolean;
  searchable?: boolean;
}

const {
  title,
  description,
  lang = defaultLang,
  showLangToast = false,
  showLanguageSwitcher = true,
  image,
  canonicalUrl: canonicalUrlProp,
  math = false,
  hideHeaderOnScroll = false,
  searchable = false,
} = Astro.props as Props;

const t = useTranslations(lang as Lang);
const siteDesc = siteConfig.description[lang as keyof typeof siteConfig.description] ?? siteConfig.description[siteConfig.defaultLang];
const pageTitle = title ?? siteConfig.name;
const pageDescription = description ?? siteDesc;
const homeHref = lang === defaultLang ? '/' : `/${lang}/`;
const searchHref = lang === defaultLang ? '/search' : `/${lang}/search`;
const canonicalUrl = canonicalUrlProp ?? `${siteConfig.siteUrl}${Astro.url.pathname}`;

// Footer: license
const licenseKey = siteConfig.license as LicensePreset | null;
const licenseInfo = licenseKey ? licensePresets[licenseKey] : null;

// Footer: language switcher URL helper
const pathname = Astro.url.pathname;
function getLangHref(targetLang: string): string {
  if (targetLang === lang) return pathname;
  if (targetLang === defaultLang) {
    // strip current lang prefix: "/en/..." → "/..."
    return pathname.replace(new RegExp(`^/${lang}(/|$)`), (_, sep) => sep ?? '/') || '/';
  }
  if (lang === defaultLang) {
    // add prefix: "/..." → "/en/..."
    return `/${targetLang}${pathname}`;
  }
  // swap prefix: "/zh/..." → "/en/..."
  return pathname.replace(new RegExp(`^/${lang}(/|$)`), `/${targetLang}$1`);
}
---

<!doctype html>
<html lang={toHtmlLang(lang)} class="antialiased">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="generator" content={Astro.generator} />
        <ClientRouter fallback="animate" />
        <title>{pageTitle}</title>
        <meta name="description" content={pageDescription} />
        <link rel="canonical" href={canonicalUrl} />

        {/* Open Graph */}
        <meta property="og:title" content={pageTitle} />
        <meta property="og:description" content={pageDescription} />
        <meta property="og:type" content="website" />
        <meta property="og:url" content={canonicalUrl} />
        <meta property="og:site_name" content={siteConfig.name} />
        <meta property="og:locale" content={lang === 'zh-cn' ? 'zh_CN' : 'en_US'} />
        {image && <meta property="og:image" content={image} />}

        {/* Twitter / X Card */}
        <meta name="twitter:card" content={image ? 'summary_large_image' : 'summary'} />
        <meta name="twitter:title" content={pageTitle} />
        <meta name="twitter:description" content={pageDescription} />
        {image && <meta name="twitter:image" content={image} />}
        {siteConfig.author.links.twitter && <meta name="twitter:site" content={`@${siteConfig.author.links.twitter}`} />}
        {siteConfig.author.links.twitter && <meta name="twitter:creator" content={`@${siteConfig.author.links.twitter}`} />}

        <slot name="head" />

        {math && (
          <link
            rel="stylesheet"
            href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css"
            crossorigin="anonymous"
          />
        )}

        {/* RSS autodiscovery */}
        {lang === defaultLang
          ? <link rel="alternate" type="application/rss+xml" title={siteConfig.name} href="/rss.xml" />
          : <link rel="alternate" type="application/rss+xml" title={`${siteConfig.name} (EN)`} href="/en-us/rss.xml" />
        }
    </head>
    <body class="flex flex-col">
        <header
          data-pagefind-ignore
          id="site-header"
          data-state="visible"
          data-hide-on-scroll={hideHeaderOnScroll ? 'true' : 'false'}
          class="fixed top-0 left-0 right-0 z-50 w-full border-b border-border/60 bg-background shadow-fluent-sm transition-transform duration-200 ease-out data-[state=hidden]:-translate-y-full"
        >
          <div class="max-w-6xl mx-auto px-3 sm:px-4 min-h-14 flex flex-wrap items-center justify-between gap-x-4 gap-y-2 py-2">
            <a href={homeHref} aria-label={t('aria.nav.home')} class="shrink-0 font-semibold text-primary tracking-tight hover:opacity-80 transition-opacity">
              {siteConfig.name}
            </a>
            <nav aria-label={t('aria.nav.main')} class="flex min-w-0 flex-1 items-center justify-end gap-3 overflow-x-auto whitespace-nowrap text-sm font-medium text-muted-foreground sm:gap-6">
              <a href={homeHref} class="hover:text-primary transition-colors">{t('nav.home')}</a>
              <a href={`${homeHref}archive`} class="hover:text-primary transition-colors">{t('nav.archive')}</a>
              <a href={`${homeHref}friends`} class="hover:text-primary transition-colors">{t('nav.friends')}</a>
              <a href={`${homeHref}about`} class="hover:text-primary transition-colors">{t('nav.about')}</a>
              <a href={searchHref} aria-label={t('aria.nav.search')} class="inline-flex items-center justify-center rounded-sm p-1.5 hover:bg-accent hover:text-primary transition-colors">
                <HugeIcon name="search" className="size-4" size={16} />
              </a>
            </nav>
          </div>
        </header>

        <main
          class="flex-1 w-full max-w-6xl mx-auto px-3 py-6 sm:px-4 sm:py-8"
          {...(searchable ? { 'data-pagefind-body': true, 'data-pagefind-filter': `lang:${lang}` } : { 'data-pagefind-ignore': true })}
        >
            <slot />
        </main>

        <footer data-pagefind-ignore class="border-t border-border/40 bg-background mt-auto">
          <div class="max-w-6xl mx-auto px-4 py-6 space-y-3 text-center text-xs text-muted-foreground">
            {showLanguageSwitcher && (
              <nav class="flex items-center justify-center gap-2" aria-label={t('aria.footer.language')}>
                {Object.entries(languages).map(([l, name]) => (
                  <a
                    href={getLangHref(l)}
                    data-lang-switch={l}
                    aria-label={t('aria.switchLanguage').replace('{lang}', languageNames[lang as Lang][l as Lang])}
                    aria-current={lang === l ? 'page' : undefined}
                    class={`px-2.5 py-1 rounded-full border text-xs font-medium transition-colors ${lang === l ? 'border-primary bg-primary/10 text-primary' : 'border-border hover:border-primary/50 hover:text-foreground'}`}
                  >
                    {name}
                  </a>
                ))}
              </nav>
            )}

            {/* License */}
            {licenseInfo && (
              <p>
                <Fragment set:html={
                  t('footer.license').replace(
                    '{license}',
                    licenseInfo.url
                      ? `<a href="${licenseInfo.url}" target="_blank" rel="noopener license" class="hover:text-primary transition-colors underline underline-offset-2">${licenseInfo.name}</a>`
                      : licenseInfo.name
                  )
                } />
              </p>
            )}

            {/* Built-with + copyright */}
            <p>© {new Date().getFullYear()} {siteConfig.author.name}. <Fragment set:html={t('footer.builtWith')} /></p>
          </div>
        </footer>

        {showLanguageSwitcher && <LanguagePreference currentLang={lang} />}

        <SmartHeader />
        <DetailsAnimator />

        {showLangToast && <LanguageToast lang={lang} />}

        <script>
          function initExternalLinks() {
            document.querySelectorAll<HTMLAnchorElement>('a[href]').forEach((anchor) => {
              const rawHref = anchor.getAttribute('href');
              if (!rawHref) return;

              let url: URL;
              try {
                url = new URL(rawHref, window.location.href);
              } catch {
                return;
              }

              if (!['http:', 'https:'].includes(url.protocol) || url.origin === window.location.origin) {
                return;
              }

              anchor.target = '_blank';

              const rel = new Set((anchor.rel || '').split(/\s+/).filter(Boolean));
              rel.add('noopener');
              rel.add('noreferrer');
              anchor.rel = Array.from(rel).join(' ');
            });
          }

          function initLocalDatetimes() {
            const htmlLang = document.documentElement.lang || navigator.language || 'en-US';
            const isZh = htmlLang.toLowerCase().startsWith('zh');

            const partsFor = (date: Date) => {
              const parts = new Intl.DateTimeFormat(isZh ? 'zh-CN' : 'en-US', {
                year: 'numeric',
                month: isZh ? '2-digit' : 'short',
                day: '2-digit',
                hour: '2-digit',
                minute: '2-digit',
                hour12: !isZh,
              }).formatToParts(date);
              const value = (type: Intl.DateTimeFormatPartTypes) => parts.find(part => part.type === type)?.value ?? '';
              const hour = value('hour') === '24' ? '00' : value('hour');
              return {
                year: value('year'),
                month: value('month'),
                day: value('day'),
                hour,
                minute: value('minute'),
                dayPeriod: value('dayPeriod'),
              };
            };

            const formatDate = (date: Date) => {
              if (isZh) {
                const { year, month, day } = partsFor(date);
                return `${year}年${month}月${day}日`;
              }
              return date.toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'short',
                day: 'numeric',
              });
            };

            const formatTime = (date: Date) => {
              if (isZh) {
                const { hour, minute } = partsFor(date);
                return `${hour}:${minute}`;
              }
              return date.toLocaleTimeString('en-US', {
                hour: 'numeric',
                minute: '2-digit',
              });
            };

            document.querySelectorAll('time[datetime]').forEach((time) => {
              const date = new Date(time.getAttribute('datetime') || '');
              if (Number.isNaN(date.valueOf())) return;

              if (time.hasAttribute('data-local-datetime')) {
                time.textContent = `${formatDate(date)} ${formatTime(date)}`;
              }

              const dateNode = time.querySelector('[data-local-date]');
              if (dateNode) dateNode.textContent = formatDate(date);

              const timeNode = time.querySelector('[data-local-time]');
              if (timeNode) timeNode.textContent = formatTime(date);
            });
          }

          initExternalLinks();
          initLocalDatetimes();
          document.addEventListener('astro:page-load', initExternalLinks);
          document.addEventListener('astro:page-load', initLocalDatetimes);
        </script>
    </body>
</html>

<style>
    html,
    body {
        margin: 0;
        width: 100%;
        height: 100%;
    }
</style>
