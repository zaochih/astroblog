---
import '../styles/global.css';
import { siteConfig, licensePresets, type LicensePreset } from '@/config';
import { useTranslations, languages, defaultLang, getLanguageName, getLangProfile, getLocalizedPath, type Lang } from '@/i18n/ui';
import { descriptionFromTitle, getSiteDescription } from '@/lib/seo';
import LanguageToast from '@/components/LanguageToast.astro';
import LanguagePreference from '@/components/LanguagePreference.astro';
import SmartHeader from '@/components/SmartHeader.astro';
import DetailsAnimator from '@/components/DetailsAnimator.astro';
import SiteAnnouncement from '@/components/SiteAnnouncement.astro';
import RouteSkeleton from '@/components/RouteSkeleton.astro';
import Icon from '@/components/Icon';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  lang?: string;
  showLangToast?: boolean;
  showLanguageSwitcher?: boolean;
  /** Optional OG image URL (absolute) */
  image?: string;
  canonicalUrl?: string;
  math?: boolean;
  hideHeaderOnScroll?: boolean;
  searchable?: boolean;
}

const {
  title,
  description,
  lang = defaultLang,
  showLangToast = false,
  showLanguageSwitcher = true,
  image,
  canonicalUrl: canonicalUrlProp,
  math = false,
  hideHeaderOnScroll = false,
  searchable = false,
} = Astro.props as Props;

const t = useTranslations(lang as Lang);
const langProfile = getLangProfile(lang);
const pageTitle = title ?? siteConfig.name;
const homeHref = lang === defaultLang ? '/' : `/${lang}/`;
const searchHref = lang === defaultLang ? '/search' : `/${lang}/search`;
const canonicalUrl = canonicalUrlProp ?? `${siteConfig.siteUrl}${Astro.url.pathname}`;
const pathname = Astro.url.pathname;
const isHomeArticleList = pathname === '/' || pathname === `/${lang}/`;
const pageDescription = description ?? (isHomeArticleList ? getSiteDescription(lang) : descriptionFromTitle(pageTitle, lang));

// Footer: license
const licenseKey = siteConfig.license as LicensePreset | null;
const licenseInfo = licenseKey ? licensePresets[licenseKey] : null;
const chinaFooterOptions = siteConfig.countrySpecificOptions.china;
const miitIcpQueryUrl = 'https://beian.miit.gov.cn/#/Integrated/recordQuery';
const mpsBeianQueryBaseUrl = 'https://www.beian.gov.cn/portal/registerSystemInfo';

function shouldShowChinaFooterRecords(currentLang: string): boolean {
  return currentLang === defaultLang;
}

const showChinaFooterRecords = shouldShowChinaFooterRecords(lang);
const miitIcpRecord = showChinaFooterRecords ? chinaFooterOptions.miitIcp.recordNumber : null;
const mpsBeianRecord = showChinaFooterRecords ? chinaFooterOptions.mpsBeian.recordNumber : null;
const mpsBeianRecordCode = mpsBeianRecord?.replace(/\D/g, '') || null;
const mpsBeianUrl = mpsBeianRecordCode
  ? `${mpsBeianQueryBaseUrl}?recordcode=${encodeURIComponent(mpsBeianRecordCode)}`
  : null;

// Footer: language switcher URL helper
function getLangHref(targetLang: string): string {
  return getLocalizedPath(pathname, lang, targetLang);
}

const localDatetimeConfig = JSON.stringify({
  locale: langProfile.dateLocale,
  useCjkFormat: langProfile.wordCountStyle === 'cjk',
});
---

<!doctype html>
<html lang={langProfile.htmlLang} class="antialiased">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/png" sizes="700x700" href="/avtr.png" />
        <link rel="apple-touch-icon" href="/avtr.png" />
        <meta name="generator" content={Astro.generator} />
        <ClientRouter fallback="animate" />
        <title>{pageTitle}</title>
        <meta name="description" content={pageDescription} />
        <link rel="canonical" href={canonicalUrl} />

        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link href="https://fonts.googleapis.com/css2?family=Comic+Neue:ital,wght@0,300;0,400;0,700;1,300;1,400;1,700&family=Google+Sans+Code:ital,wght,MONO@0,300..800,1;1,300..800,1&family=Google+Sans+Flex:opsz,wght@6..144,1..1000&display=swap" rel="stylesheet">

        {/* Open Graph */}
        <meta property="og:title" content={pageTitle} />
        <meta property="og:description" content={pageDescription} />
        <meta property="og:type" content="website" />
        <meta property="og:url" content={canonicalUrl} />
        <meta property="og:site_name" content={siteConfig.name} />
        <meta property="og:locale" content={langProfile.ogLocale} />
        {image && <meta property="og:image" content={image} />}

        {/* Twitter / X Card */}
        <meta name="twitter:card" content={image ? 'summary_large_image' : 'summary'} />
        <meta name="twitter:title" content={pageTitle} />
        <meta name="twitter:description" content={pageDescription} />
        {image && <meta name="twitter:image" content={image} />}
        {siteConfig.author.links.twitter && <meta name="twitter:site" content={`@${siteConfig.author.links.twitter}`} />}
        {siteConfig.author.links.twitter && <meta name="twitter:creator" content={`@${siteConfig.author.links.twitter}`} />}

        <slot name="head" />

        {math && (
          <link
            rel="stylesheet"
            href="/lib/katex/katex.min.css"
          />
        )}

        {/* RSS autodiscovery */}
        {lang === defaultLang
          ? <link rel="alternate" type="application/rss+xml" title={siteConfig.name} href="/rss.xml" />
          : <link rel="alternate" type="application/rss+xml" title={`${siteConfig.name} (${langProfile.label})`} href={`/${lang}/rss.xml`} />
        }
    </head>
    <body
      class="flex min-h-screen flex-col"
      data-local-datetime-config={localDatetimeConfig}
    >
        <a
          href="#main-content"
          class="sr-only focus:not-sr-only focus:fixed focus:left-3 focus:top-3 focus:z-[100] focus:rounded-md focus:bg-primary focus:px-3 focus:py-2 focus:text-sm focus:font-medium focus:text-primary-foreground focus:shadow-fluent-md"
        >
          {t('aria.skipToContent')}
        </a>

        <SiteAnnouncement lang={lang} />

        <header
          data-pagefind-ignore
          id="site-header"
          data-state="visible"
          data-hide-on-scroll={hideHeaderOnScroll ? 'true' : 'false'}
          class="sticky top-0 z-50 w-full border-b border-border/60 bg-background/90 shadow-fluent-sm backdrop-blur-md transition-transform duration-200 ease-out data-[state=hidden]:-translate-y-full"
        >
          <div class="max-w-6xl mx-auto px-3 sm:px-4 min-h-14 flex flex-wrap items-center justify-between gap-x-4 gap-y-2 py-2">
            <a href={homeHref} data-skeleton-kind="feed" aria-label={t('aria.nav.home')} class="shrink-0 font-semibold text-primary tracking-tight hover:opacity-80 transition-opacity">
              {siteConfig.name}
            </a>
            <nav aria-label={t('aria.nav.main')} class="flex min-w-0 flex-1 items-center justify-end gap-1 overflow-x-auto whitespace-nowrap text-sm font-medium text-muted-foreground sm:gap-2">
              <a href={homeHref} data-skeleton-kind="feed" class="rounded-sm px-2 py-1.5 hover:bg-support/10 hover:text-support transition-colors">{t('nav.home')}</a>
              <a href={`${homeHref}archive`} data-skeleton-kind="archive" class="rounded-sm px-2 py-1.5 hover:bg-support/10 hover:text-support transition-colors">{t('nav.archive')}</a>
              <a href={`${homeHref}friends`} data-skeleton-kind="friends" class="rounded-sm px-2 py-1.5 hover:bg-support/10 hover:text-support transition-colors">{t('nav.friends')}</a>
              <a href={`${homeHref}about`} data-skeleton-kind="page" class="rounded-sm px-2 py-1.5 hover:bg-support/10 hover:text-support transition-colors">{t('nav.about')}</a>
              <a href={searchHref} data-skeleton-kind="search" aria-label={t('aria.nav.search')} class="inline-flex items-center justify-center rounded-sm p-1.5 hover:bg-support/10 hover:text-support transition-colors">
                <Icon name="search" className="size-4" size={16} />
              </a>
            </nav>
          </div>
        </header>

        <main
          id="main-content"
          class="flex-1 w-full max-w-6xl mx-auto px-3 py-6 sm:px-4 sm:py-8"
          {...(searchable ? { 'data-pagefind-body': true, 'data-pagefind-filter': `lang:${lang}` } : { 'data-pagefind-ignore': true })}
        >
            <div data-route-content>
              <slot />
            </div>
            <RouteSkeleton />
        </main>

        <footer data-pagefind-ignore data-site-footer class="border-t border-border/40 bg-background mt-auto">
          <div class="max-w-6xl mx-auto px-4 py-6 space-y-3 text-center text-xs text-muted-foreground">
            {showLanguageSwitcher && (
              <nav class="flex items-center justify-center gap-2" aria-label={t('aria.footer.language')}>
                {Object.entries(languages).map(([l, name]) => (
                  <a
                    href={getLangHref(l)}
                    data-footer-lang
                    data-lang-switch={l}
                    aria-label={t('aria.switchLanguage').replace('{lang}', getLanguageName(l, lang))}
                    aria-current={lang === l ? 'page' : undefined}
                    class={`px-2.5 py-1 rounded-full border text-xs font-medium transition-colors ${lang === l ? 'border-primary bg-primary/10 text-primary' : 'border-border hover:border-primary/50 hover:text-foreground'}`}
                  >
                    {name}
                  </a>
                ))}
              </nav>
            )}

            {/* License */}
            {licenseInfo && (
              <p>
                <Fragment set:html={
                  t('footer.license').replace(
                    '{license}',
                    licenseInfo.url
                      ? `<a href="${licenseInfo.url}" target="_blank" rel="noopener license" class="hover:text-primary transition-colors">${licenseInfo.name}</a>`
                      : licenseInfo.name
                  )
                } />
              </p>
            )}

            {/* Built-with + copyright */}
            <p>© {new Date().getFullYear()} {siteConfig.author.name}. <Fragment set:html={t('footer.builtWith')} /></p>

            {(miitIcpRecord || (mpsBeianRecord && mpsBeianUrl)) && (
              <p class="flex flex-wrap items-center justify-center gap-x-3 gap-y-1">
                {miitIcpRecord && (
                  <a href={miitIcpQueryUrl} target="_blank" rel="noopener noreferrer" class="hover:text-primary transition-colors">
                    {miitIcpRecord}
                  </a>
                )}
                {miitIcpRecord && mpsBeianRecord && mpsBeianUrl && <span aria-hidden="true">·</span>}
                {mpsBeianRecord && mpsBeianUrl && (
                  <a href={mpsBeianUrl} target="_blank" rel="noopener noreferrer" class="hover:text-primary transition-colors">
                    {mpsBeianRecord}
                  </a>
                )}
              </p>
            )}
          </div>
        </footer>

        <style>
          :global([data-site-footer] a:not([data-footer-lang])) {
            font-weight: 500;
            text-decoration-line: underline;
            text-underline-offset: 2px;
            text-decoration-color: color-mix(in oklab, currentColor 40%, transparent);
          }
          :global([data-site-footer] a:not([data-footer-lang]):hover) {
            text-decoration-color: currentColor;
          }
        </style>

        {showLanguageSwitcher && <LanguagePreference currentLang={lang} />}

        <SmartHeader />
        <DetailsAnimator />

        {showLangToast && <LanguageToast lang={lang} />}

        <script is:inline>
          function inferRouteSkeletonKind(url) {
            const path = url.pathname.replace(/\/+$/, '') || '/';
            const segments = path.split('/').filter(Boolean);
            const first = segments[0];
            const routeStart = first && first.includes('-') ? 1 : 0;
            const route = segments[routeStart] || '';

            if (path === '/' || route === '' || route === 'page') return 'feed';
            if (route === 'post') return 'post-without-toc';
            if (route === 'archive') return 'archive';
            if (route === 'tags' || route === 'categories') return 'taxonomy';
            if (route === 'friends') return 'friends';
            if (route === 'search') return 'search';
            return 'page';
          }

          function initRouteSkeleton() {
            if (window.__lczRouteSkeletonBound) return;
            window.__lczRouteSkeletonBound = true;

            const validKinds = new Set([
              'feed',
              'post-with-toc',
              'post-without-toc',
              'archive',
              'taxonomy',
              'friends',
              'search',
              'page',
            ]);
            let pendingKind = null;
            let loadingTimer = 0;

            const getSkeleton = () => document.querySelector('[data-route-skeleton]');

            const setKind = (kind) => {
              const skeleton = getSkeleton();
              const nextKind = validKinds.has(kind) ? kind : 'page';
              if (skeleton) skeleton.setAttribute('data-skeleton-kind', nextKind);
            };

            const clearLoading = () => {
              if (loadingTimer) {
                window.clearTimeout(loadingTimer);
                loadingTimer = 0;
              }
              document.body?.removeAttribute('data-route-loading');
              document.body?.removeAttribute('data-route-loading-exit');
              pendingKind = null;
            };

            const clearLoadingAfterReveal = () => {
              if (loadingTimer) {
                window.clearTimeout(loadingTimer);
                loadingTimer = 0;
              }

              if (document.body?.dataset.routeLoading === 'true') {
                document.body.setAttribute('data-route-loading-exit', 'true');
                window.setTimeout(clearLoading, 420);
                return;
              }

              clearLoading();
            };

            const clearPreparationTimer = () => {
              if (!loadingTimer) return;
              window.clearTimeout(loadingTimer);
              loadingTimer = 0;
            };

            document.addEventListener('click', (event) => {
              if (event.defaultPrevented || event.button !== 0 || event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) {
                return;
              }

              const target = event.target;
              const anchor = target instanceof Element ? target.closest('a[href]') : null;
              if (!anchor) return;
              if (anchor.target && anchor.target !== '_self') return;
              if (anchor.hasAttribute('download')) return;

              let url;
              try {
                url = new URL(anchor.getAttribute('href') || '', window.location.href);
              } catch {
                return;
              }

              if (url.origin !== window.location.origin) return;
              if (url.pathname === window.location.pathname && url.search === window.location.search) return;

              pendingKind = anchor.dataset.skeletonKind || inferRouteSkeletonKind(url);
            }, true);

            document.addEventListener('astro:before-preparation', (event) => {
              const to = event.to instanceof URL ? event.to : new URL(window.location.href);
              const kind = pendingKind || inferRouteSkeletonKind(to);
              setKind(kind);
              if (loadingTimer) window.clearTimeout(loadingTimer);
              document.body?.removeAttribute('data-route-loading-exit');
              loadingTimer = window.setTimeout(() => {
                window.scrollTo({ top: 0, left: 0, behavior: 'instant' });
                document.body?.setAttribute('data-route-loading', 'true');
              }, 150);
            });

            document.addEventListener('astro:before-swap', (event) => {
              if (document.body?.dataset.routeLoading !== 'true') return;

              event.newDocument.body.setAttribute('data-route-loading', 'true');
              event.newDocument.body.removeAttribute('data-route-loading-exit');

              const currentKind = getSkeleton()?.getAttribute('data-skeleton-kind') || pendingKind || 'page';
              const nextSkeleton = event.newDocument.querySelector('[data-route-skeleton]');
              if (nextSkeleton) {
                nextSkeleton.setAttribute('data-skeleton-kind', validKinds.has(currentKind) ? currentKind : 'page');
              }
            });

            document.addEventListener('astro:after-preparation', clearPreparationTimer);
            document.addEventListener('astro:page-load', clearLoadingAfterReveal);
          }

          function initExternalLinks() {
            document.querySelectorAll('a[href]').forEach((anchor) => {
              const rawHref = anchor.getAttribute('href');
              if (!rawHref) return;

              let url;
              try {
                url = new URL(rawHref, window.location.href);
              } catch {
                return;
              }

              if (!['http:', 'https:'].includes(url.protocol) || url.origin === window.location.origin) {
                return;
              }

              anchor.target = '_blank';

              const rel = new Set((anchor.rel || '').split(/\s+/).filter(Boolean));
              rel.add('noopener');
              rel.add('noreferrer');
              anchor.rel = Array.from(rel).join(' ');
            });
          }

          function initLocalDatetimes() {
            const rawConfig = document.body?.dataset.localDatetimeConfig;
            let config = {};
            try {
              config = rawConfig ? JSON.parse(rawConfig) : {};
            } catch {
              config = {};
            }
            const locale = config.locale || document.documentElement.lang || navigator.language || 'en-US';
            const useCjkFormat = Boolean(config.useCjkFormat);

            const partsFor = (date) => {
              const parts = new Intl.DateTimeFormat(locale, {
                year: 'numeric',
                month: useCjkFormat ? '2-digit' : 'short',
                day: '2-digit',
                hour: '2-digit',
                minute: '2-digit',
                hour12: !useCjkFormat,
              }).formatToParts(date);
              const value = (type) => parts.find(part => part.type === type)?.value ?? '';
              const hour = value('hour') === '24' ? '00' : value('hour');
              return {
                year: value('year'),
                month: value('month'),
                day: value('day'),
                hour,
                minute: value('minute'),
                dayPeriod: value('dayPeriod'),
              };
            };

            const formatDate = (date) => {
              if (useCjkFormat) {
                const { year, month, day } = partsFor(date);
                return `${year}年${month}月${day}日`;
              }
              return date.toLocaleDateString(locale, {
                year: 'numeric',
                month: 'short',
                day: 'numeric',
              });
            };

            const formatTime = (date) => {
              if (useCjkFormat) {
                const { hour, minute } = partsFor(date);
                return `${hour}:${minute}`;
              }
              return date.toLocaleTimeString(locale, {
                hour: 'numeric',
                minute: '2-digit',
              });
            };

            document.querySelectorAll('time[datetime]').forEach((time) => {
              const date = new Date(time.getAttribute('datetime') || '');
              if (Number.isNaN(date.valueOf())) return;

              if (time.hasAttribute('data-local-datetime')) {
                time.textContent = `${formatDate(date)} ${formatTime(date)}`;
              }

              const dateNode = time.querySelector('[data-local-date]');
              if (dateNode) dateNode.textContent = formatDate(date);

              const timeNode = time.querySelector('[data-local-time]');
              if (timeNode) timeNode.textContent = formatTime(date);
            });
          }

          function initLinkHoverReset() {
            if (window.__lczLinkHoverResetBound) return;
            window.__lczLinkHoverResetBound = true;

            const suppressHover = () => {
              document.documentElement.setAttribute('data-link-hover-suppressed', 'true');
            };

            const restoreHover = () => {
              document.documentElement.removeAttribute('data-link-hover-suppressed');
            };

            const enableKeyboardFocus = () => {
              document.documentElement.setAttribute('data-keyboard-focus', 'true');
              restoreHover();
            };

            const disableKeyboardFocus = () => {
              document.documentElement.removeAttribute('data-keyboard-focus');
            };

            document.addEventListener('pointerdown', (event) => {
              if (event.button !== 0) return;
              const target = event.target;
              const anchor = target instanceof Element ? target.closest('a[href]') : null;
              if (!anchor) return;
              disableKeyboardFocus();
              suppressHover();
            }, true);

            document.addEventListener('click', (event) => {
              const target = event.target;
              const anchor = target instanceof Element ? target.closest('a[href]') : null;
              if (!anchor) return;
              disableKeyboardFocus();
              suppressHover();
            }, true);

            window.addEventListener('blur', () => {
              const active = document.activeElement;
              const anchor = active instanceof Element ? active.closest('a[href]') : null;
              if (!anchor) return;
              disableKeyboardFocus();
              suppressHover();
            });

            document.addEventListener('visibilitychange', () => {
              if (document.visibilityState !== 'hidden') return;
              const active = document.activeElement;
              const anchor = active instanceof Element ? active.closest('a[href]') : null;
              if (!anchor) return;
              disableKeyboardFocus();
              suppressHover();
            });

            document.addEventListener('pointermove', restoreHover, true);
            document.addEventListener('mousemove', restoreHover, true);
            document.addEventListener('keydown', (event) => {
              if (event.key === 'Tab') enableKeyboardFocus();
            }, true);
            document.addEventListener('astro:page-load', restoreHover);
          }

          if (!window.__lczLayoutEnhancementsBound) {
            window.__lczLayoutEnhancementsBound = true;
            document.addEventListener('astro:page-load', () => {
              initExternalLinks();
              initLocalDatetimes();
              initLinkHoverReset();
            });
          }

          initExternalLinks();
          initLocalDatetimes();
          initLinkHoverReset();
          initRouteSkeleton();
        </script>
    </body>
</html>

<style>
    html {
        margin: 0;
        width: 100%;
        min-height: 100%;
    }

    body {
        margin: 0;
        width: 100%;
        min-height: 100vh;
    }

    :global(body[data-route-loading='true']:not([data-route-loading-exit='true']) [data-route-content]) {
        display: none;
    }
</style>
