---
import { siteConfig } from '@/config';
import { useTranslations, type Lang } from '@/i18n/ui';

interface Props {
  lang: Lang;
  term: string;
  enabled?: boolean;
}

const { lang, term, enabled = true } = Astro.props as Props;
const t = useTranslations(lang);
const comments = siteConfig.comments;
const isConfigured = Boolean(
  comments.enabled &&
  comments.repo &&
  comments.repoId &&
  comments.category &&
  comments.categoryId,
);
const giscusLang = lang === 'zh-cn' ? 'zh-CN' : 'en';
const giscusConfig = JSON.stringify({
  repo: comments.repo,
  repoId: comments.repoId,
  category: comments.category,
  categoryId: comments.categoryId,
  term,
  lang: giscusLang,
});
---

{enabled && isConfigured && (
  <section
    class="mt-12 border-t border-border/50 pt-8"
    aria-labelledby="comments-title"
    data-giscus-comments
    data-giscus-config={giscusConfig}
  >
    <div class="mb-5 space-y-1">
      <h2 id="comments-title" class="text-xl font-semibold text-foreground">
        {t('comments.title')}
      </h2>
      <p class="text-xs leading-relaxed text-muted-foreground">
        {t('comments.description')}{' '}
        <a
          href={comments.privacyUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="text-primary underline underline-offset-2"
        >
          {t('comments.privacy')}
        </a>
      </p>
    </div>

    <div data-giscus-host></div>

    <script is:inline>
      (() => {
        function loadGiscus(container) {
          const host = container.querySelector('[data-giscus-host]');
          if (!host || host.dataset.loaded === 'true') return;

          const config = JSON.parse(container.dataset.giscusConfig || '{}');
          if (!config.repo || !config.repoId || !config.category || !config.categoryId || !config.term) return;

          host.textContent = '';
          const script = document.createElement('script');
          script.src = 'https://giscus.app/client.js';
          script.async = true;
          script.crossOrigin = 'anonymous';
          script.setAttribute('data-repo', config.repo);
          script.setAttribute('data-repo-id', config.repoId);
          script.setAttribute('data-category', config.category);
          script.setAttribute('data-category-id', config.categoryId);
          script.setAttribute('data-mapping', 'specific');
          script.setAttribute('data-term', config.term);
          script.setAttribute('data-strict', '1');
          script.setAttribute('data-reactions-enabled', '1');
          script.setAttribute('data-emit-metadata', '0');
          script.setAttribute('data-input-position', 'top');
          script.setAttribute('data-theme', 'preferred_color_scheme');
          script.setAttribute('data-lang', config.lang || 'en');
          host.append(script);
          host.dataset.loaded = 'true';
        }

        function initGiscus(root = document) {
          root.querySelectorAll('[data-giscus-comments]').forEach(loadGiscus);
        }

        if (!window.__lczGiscusBound) {
          window.__lczGiscusBound = true;
          document.addEventListener('astro:page-load', () => initGiscus());
          document.addEventListener('astro:after-swap', () => requestAnimationFrame(() => initGiscus()));
        }

        initGiscus();
      })();
    </script>
  </section>
)}
