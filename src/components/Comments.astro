---
import { siteConfig } from '@/config';
import { useTranslations, type Lang } from '@/i18n/ui';

interface Props {
  lang: Lang;
  term: string;
  enabled?: boolean;
}

const { lang, term, enabled = true } = Astro.props as Props;
const t = useTranslations(lang);
const comments = siteConfig.comments;
const isConfigured = Boolean(
  comments.enabled &&
  comments.repo &&
  comments.repoId &&
  comments.category &&
  comments.categoryId,
);
const giscusLang = lang === 'zh-cn' ? 'zh-CN' : 'en';
---

{enabled && isConfigured && (
  <section class="mt-12 border-t border-border/50 pt-8" aria-labelledby="comments-title">
    <div class="mb-5 space-y-1">
      <h2 id="comments-title" class="text-xl font-semibold text-foreground">
        {t('comments.title')}
      </h2>
      <p class="text-xs leading-relaxed text-muted-foreground">
        {t('comments.description')}{' '}
        <a
          href={comments.privacyUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="text-primary underline underline-offset-2"
        >
          {t('comments.privacy')}
        </a>
      </p>
    </div>

    <script
      is:inline
      src="https://giscus.app/client.js"
      data-repo={comments.repo}
      data-repo-id={comments.repoId}
      data-category={comments.category}
      data-category-id={comments.categoryId}
      data-mapping="specific"
      data-term={term}
      data-strict="1"
      data-reactions-enabled="1"
      data-emit-metadata="0"
      data-input-position="top"
      data-theme="preferred_color_scheme"
      data-lang={giscusLang}
      crossorigin="anonymous"
      async
    ></script>
  </section>
)}
