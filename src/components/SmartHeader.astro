<script is:inline>
  (() => {
    const existing = window.__lczSmartHeader;
    if (existing) {
      existing.refresh();
      return;
    }

    const state = {
      lastY: getScrollY(),
      ticking: false,
      hideAfter: 96,
      directionThreshold: 4,
      showAfterUp: 24,
      upwardDistance: 0,
      observedHeader: null,
      headerHeight: 0,
      headerState: 'visible',
      anchorLocked: false,
    };

    const resizeObserver = new ResizeObserver((entries) => {
      const entry = entries[0];
      const borderBox = entry.borderBoxSize?.[0];
      const height = Math.ceil(borderBox?.blockSize ?? entry.contentRect.height);
      syncHeaderHeight(height);
    });

    function getHeader() {
      return document.getElementById('site-header');
    }

    function isEnabled(header = getHeader()) {
      return header?.dataset.hideOnScroll === 'true';
    }

    function getScrollY() {
      return Math.max(0, window.scrollY || window.pageYOffset || 0);
    }

    function getHashTarget(hash) {
      if (!hash || hash === '#') return null;
      const rawId = hash.slice(1);
      try {
        return document.getElementById(decodeURIComponent(rawId)) ?? document.getElementById(rawId);
      } catch {
        return document.getElementById(rawId);
      }
    }

    function isSamePageHashHref(href) {
      let url;
      try {
        url = new URL(href, window.location.href);
      } catch {
        return false;
      }

      return (
        url.origin === window.location.origin &&
        url.pathname === window.location.pathname &&
        url.search === window.location.search &&
        Boolean(getHashTarget(url.hash))
      );
    }

    function lockHeaderForAnchorNavigation() {
      state.anchorLocked = true;
      setHeaderState('visible');
      state.lastY = getScrollY();
      state.upwardDistance = 0;
    }

    function releaseAnchorNavigationLock() {
      if (!state.anchorLocked) return;
      state.anchorLocked = false;
      state.lastY = getScrollY();
      state.upwardDistance = 0;
      requestUpdate();
    }

    function isAnchorNavigationLocked() {
      return state.anchorLocked;
    }

    function syncHeaderHeight(height) {
      const value = `${height}px`;
      if (height === state.headerHeight) return;
      state.headerHeight = height;
      document.documentElement.style.setProperty('--site-header-height', value);
      syncVisibleHeaderHeight(state.headerState);
    }

    function syncVisibleHeaderHeight(value = state.headerState) {
      const visibleHeight = value === 'hidden' ? '0px' : `${state.headerHeight}px`;
      document.documentElement.style.setProperty('--site-header-visible-height', visibleHeight);
    }

    function observeHeader() {
      const header = getHeader();
      if (!header || header === state.observedHeader) return;
      if (state.observedHeader) resizeObserver.unobserve(state.observedHeader);
      state.observedHeader = header;
      resizeObserver.observe(header);
    }

    function setHeaderState(value) {
      const header = getHeader();
      state.headerState = value;
      if (header) header.dataset.state = value;
      syncVisibleHeaderHeight(value);
    }

    function update() {
      const header = getHeader();
      if (!header) {
        state.ticking = false;
        return;
      }

      if (!isEnabled(header)) {
        state.upwardDistance = 0;
        setHeaderState('visible');
        state.lastY = getScrollY();
        state.ticking = false;
        return;
      }

      if (isAnchorNavigationLocked()) {
        state.upwardDistance = 0;
        setHeaderState('visible');
        state.lastY = getScrollY();
        state.ticking = false;
        return;
      }

      const currentY = getScrollY();
      const delta = currentY - state.lastY;

      if (currentY <= 8) {
        state.upwardDistance = 0;
        setHeaderState('visible');
      } else if (delta > state.directionThreshold && currentY > state.hideAfter) {
        state.upwardDistance = 0;
        setHeaderState('hidden');
      } else if (delta < 0) {
        state.upwardDistance += Math.abs(delta);
        if (state.upwardDistance >= state.showAfterUp) {
          setHeaderState('visible');
        }
      } else if (delta > 0) {
        state.upwardDistance = 0;
      }

      if (delta < -state.directionThreshold && currentY <= state.hideAfter) {
        setHeaderState('visible');
      }

      state.lastY = currentY;
      state.ticking = false;
    }

    function requestUpdate() {
      if (state.ticking) return;
      state.ticking = true;
      requestAnimationFrame(update);
    }

    function refresh() {
      observeHeader();
      state.lastY = getScrollY();
      state.upwardDistance = 0;
      state.ticking = false;
      setHeaderState('visible');
    }

    function handleAnchorClick(event) {
      if (event.defaultPrevented || event.button !== 0 || event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) {
        return;
      }

      const link = event.target instanceof Element
        ? event.target.closest('a[href]')
        : null;
      if (!link || !isSamePageHashHref(link.href)) return;

      lockHeaderForAnchorNavigation();
    }

    function refreshAfterLayout() {
      refresh();
      requestAnimationFrame(refresh);
    }

    window.addEventListener('scroll', requestUpdate, { passive: true });
    window.addEventListener('resize', refreshAfterLayout, { passive: true });
    window.addEventListener('pageshow', refreshAfterLayout);
    window.addEventListener('hashchange', lockHeaderForAnchorNavigation);
    window.addEventListener('wheel', releaseAnchorNavigationLock, { passive: true });
    window.addEventListener('touchstart', releaseAnchorNavigationLock, { passive: true });
    window.addEventListener('keydown', releaseAnchorNavigationLock);
    document.addEventListener('click', handleAnchorClick, true);
    document.addEventListener('astro:page-load', refreshAfterLayout);
    document.addEventListener('astro:after-swap', refreshAfterLayout);

    window.__lczSmartHeader = {
      refresh: refreshAfterLayout,
      setState(value) {
        const header = getHeader();
        if (!header) return;
        setHeaderState(value === 'hidden' && isEnabled(header) ? 'hidden' : 'visible');
        state.lastY = getScrollY();
        state.upwardDistance = 0;
      },
      getHeight() {
        return state.headerHeight;
      },
      isHideEnabled() {
        return isEnabled();
      },
    };
    refreshAfterLayout();
  })();
</script>
