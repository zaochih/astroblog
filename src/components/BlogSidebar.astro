---
import Icon from '@/components/Icon';
import { siteConfig } from '@/config';
import type { CollectionEntry } from 'astro:content';
import { getTagHref, getCategoryHref, countWords, formatWordCount } from '@/lib/content';
import { getTagName, getCategoryName, resolveCategoryKey, resolveTagKey } from '@/i18n/taxonomy';
import { getLocalizedValue, useTranslations, type Lang } from '@/i18n/ui';

interface Props {
  posts: Array<{ post: CollectionEntry<'blog'>; slug: string }>;
  lang: string;
  side: 'left' | 'right';
}

const { posts, lang, side } = Astro.props;
const t = useTranslations(lang as Lang);
const bio = getLocalizedValue(siteConfig.author.bio, lang) ?? siteConfig.author.bio[siteConfig.defaultLang];
const allTags = [...new Set(posts.flatMap(({ post }) => post.data.tags ?? []).map(resolveTagKey))]
  .sort((a, b) => getTagName(a, lang as Lang).localeCompare(getTagName(b, lang as Lang), lang));
const categoryCounts = posts.reduce((counts, { post }) => {
  if (!post.data.category) return counts;
  const category = resolveCategoryKey(post.data.category);
  counts.set(category, (counts.get(category) ?? 0) + 1);
  return counts;
}, new Map<string, number>());
const allCategories = [...categoryCounts.keys()]
  .sort((a, b) => getCategoryName(a, lang as Lang).localeCompare(getCategoryName(b, lang as Lang), lang));
const totalWords = posts.reduce((sum, { post }) => sum + countWords(post.body ?? ''), 0);
const totalWordsFormatted = formatWordCount(totalWords, lang);
const [wordTotal, ...wordUnit] = totalWordsFormatted.split(' ');
---

{side === 'left' ? (
<aside class="mb-6 space-y-4 lg:sticky lg:top-20 lg:mb-0 lg:self-start">
  <div class="flex items-center gap-4 rounded-lg border border-border/50 bg-card p-4 lg:flex-col lg:gap-3 lg:p-5">
    <img
      src={siteConfig.author.avatar}
      alt={siteConfig.author.name}
      class="size-14 rounded-full border-2 border-primary/20 object-cover lg:size-20"
    />
    <div class="min-w-0 flex-1 text-left lg:text-center">
      <h2 class="text-sm font-semibold text-foreground">{siteConfig.author.name}</h2>
      <p class="mt-1 text-xs text-muted-foreground leading-relaxed">{bio}</p>
      <div class="mt-2 flex items-center gap-3 lg:justify-center">
        {siteConfig.author.links.github && (
          <a
            href={siteConfig.author.links.github}
            target="_blank"
            rel="noopener noreferrer me"
            class="text-muted-foreground hover:text-primary transition-colors"
            aria-label={t('aria.authorGithub').replace('{name}', siteConfig.author.name)}
            title="GitHub"
          >
            <Icon name="github" className="size-4" size={16} />
          </a>
        )}
        {siteConfig.author.links.twitter && (
          <a
            href={`https://x.com/${siteConfig.author.links.twitter}`}
            target="_blank"
            rel="noopener noreferrer me"
            class="text-muted-foreground hover:text-primary transition-colors"
            aria-label={t('aria.authorTwitter').replace('{name}', siteConfig.author.name)}
            title="X / Twitter"
          >
            <Icon name="x" className="size-4" size={16} />
          </a>
        )}
      </div>
    </div>
  </div>

  <div class="grid grid-cols-4 gap-px overflow-hidden rounded-lg border border-border/50 bg-border/50 lg:grid-cols-2">
    <div class="flex flex-col items-center py-3 bg-card">
      <span class="text-base font-bold text-foreground">{posts.length}</span>
      <span class="text-[10px] text-muted-foreground">{t('stats.posts')}</span>
    </div>
    <div class="flex flex-col items-center py-3 bg-card">
      <span class="text-base font-bold text-foreground">{allCategories.length}</span>
      <span class="text-[10px] text-muted-foreground">{t('stats.categories')}</span>
    </div>
    <div class="flex flex-col items-center py-3 bg-card">
      <span class="text-base font-bold text-foreground">{allTags.length}</span>
      <span class="text-[10px] text-muted-foreground">{t('stats.tags')}</span>
    </div>
    <div class="flex flex-col items-center py-3 bg-card">
      <span class="text-base font-bold text-foreground">{wordTotal}</span>
      <span class="text-[10px] text-muted-foreground">{wordUnit.join(' ')}</span>
    </div>
  </div>
</aside>
) : (
<aside class="mt-8 space-y-3 lg:sticky lg:top-20 lg:mt-0 lg:self-start lg:space-y-6">
  {allCategories.length > 0 && (
    <details class="animated-details rounded-lg border border-border/50 bg-card p-4 lg:block lg:p-5" open>
      <summary class="cursor-pointer select-none text-xs font-semibold uppercase tracking-wider text-foreground lg:pointer-events-none lg:mb-3 lg:list-none">
        {t('sidebar.categories')}
      </summary>
      <div class="details-content">
        <div class="mt-3 flex flex-wrap gap-1.5 lg:mt-0 lg:flex-col lg:gap-0.5">
          {allCategories.map(category => (
            <a
              href={getCategoryHref(category, lang)}
              aria-label={t('aria.category').replace('{name}', getCategoryName(category, lang as Lang))}
              class="group relative flex items-center gap-3 rounded-md bg-muted px-2.5 py-1 text-xs leading-6 text-muted-foreground transition-colors hover:bg-muted/80 hover:text-foreground lg:bg-transparent lg:py-0.5 lg:pl-3 lg:pr-2"
            >
              <span class="absolute left-1 top-1/2 hidden h-4 w-0.5 -translate-y-1/2 rounded-full bg-primary opacity-0 transition-opacity group-hover:opacity-100 lg:block"></span>
              <span class="min-w-0 flex-1 truncate">{getCategoryName(category, lang as Lang)}</span>
              <span class="rounded-full bg-background/70 px-1.5 py-0.5 text-[10px] font-medium leading-none text-muted-foreground transition-colors group-hover:text-foreground">
                {categoryCounts.get(category)}
              </span>
            </a>
          ))}
        </div>
      </div>
    </details>
  )}

  {allTags.length > 0 && (
    <details class="animated-details rounded-lg border border-border/50 bg-card p-4 lg:block lg:p-5" open>
      <summary class="cursor-pointer select-none text-xs font-semibold uppercase tracking-wider text-foreground lg:pointer-events-none lg:mb-3 lg:list-none">
        {t('sidebar.tags')}
      </summary>
      <div class="details-content">
        <div class="mt-3 flex flex-wrap gap-1.5 lg:mt-0">
          {allTags.map(tag => (
            <a
              href={getTagHref(tag, lang)}
              aria-label={t('aria.tag').replace('{name}', getTagName(tag, lang as Lang))}
              class="text-xs px-2 py-0.5 rounded-md bg-muted text-muted-foreground hover:bg-primary/10 hover:text-primary transition-colors"
            >
              #{getTagName(tag, lang as Lang)}
            </a>
          ))}
        </div>
      </div>
    </details>
  )}
</aside>
)}
