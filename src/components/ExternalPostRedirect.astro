---
import Layout from '@/layouts/Layout.astro';
import { buttonVariants } from '@/components/ui/button';
import { siteConfig } from '@/config';
import { useTranslations, type Lang } from '@/i18n/ui';

interface Props {
  title: string;
  description?: string;
  lang: Lang;
  redirectUrl: string;
}

const { title, description, lang, redirectUrl } = Astro.props as Props;
const t = useTranslations(lang);
---

<Layout
  title={`${title} | ${siteConfig.name}`}
  description={description}
  lang={lang}
  canonicalUrl={redirectUrl}
>
  <Fragment slot="head">
    <meta http-equiv="refresh" content={`0;url=${redirectUrl}`} />
  </Fragment>

  <article class="mx-auto mt-16 max-w-2xl text-center">
    <p class="mb-3 text-sm font-medium text-muted-foreground">
      {t('external.redirecting')}
    </p>
    <h1 class="mb-6 text-3xl font-bold tracking-tight text-foreground">
      {title}
    </h1>
    <p class="mb-8 text-sm leading-relaxed text-muted-foreground">
      {t('external.redirectHint')}
    </p>
    <a
      href={redirectUrl}
      aria-label={t('aria.externalContinue').replace('{title}', title)}
      class={`${buttonVariants({ variant: 'default', size: 'lg' })} rounded-lg px-6 text-sm`}
    >
      {t('external.continue')}
    </a>
  </article>

  <script is:inline define:vars={{ redirectUrl }}>
    window.location.replace(redirectUrl);
  </script>
</Layout>
