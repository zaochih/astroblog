---
import Layout from '@/layouts/Layout.astro';
import { buttonVariants } from '@/components/ui/button';
import { siteConfig } from '@/config';
import type { Lang } from '@/i18n/ui';

interface Props {
  title: string;
  description?: string;
  lang: Lang;
  redirectUrl: string;
}

const { title, description, lang, redirectUrl } = Astro.props as Props;
const isZh = lang === 'zh-cn';
---

<Layout
  title={`${title} | ${siteConfig.name}`}
  description={description}
  lang={lang}
  canonicalUrl={redirectUrl}
>
  <Fragment slot="head">
    <meta http-equiv="refresh" content={`0;url=${redirectUrl}`} />
  </Fragment>

  <article class="mx-auto mt-16 max-w-2xl text-center">
    <p class="mb-3 text-sm font-medium text-muted-foreground">
      {isZh ? '正在跳转到外部文章' : 'Redirecting to the external article'}
    </p>
    <h1 class="mb-6 text-3xl font-bold tracking-tight text-foreground">
      {title}
    </h1>
    <p class="mb-8 text-sm leading-relaxed text-muted-foreground">
      {isZh
        ? '如果浏览器没有自动跳转，请使用下面的链接继续阅读。'
        : 'If your browser does not redirect automatically, use the link below to continue reading.'}
    </p>
    <a href={redirectUrl} class={`${buttonVariants({ variant: 'default', size: 'lg' })} rounded-lg px-6 text-sm`}>
      {isZh ? '继续阅读' : 'Continue reading'}
    </a>
  </article>

  <script is:inline define:vars={{ redirectUrl }}>
    window.location.replace(redirectUrl);
  </script>
</Layout>
