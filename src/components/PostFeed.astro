---
import type { CollectionEntry } from 'astro:content';
import { getPostHref, getTagHref, getCategoryHref, countWords, readingMinutes, formatDateTime } from '@/lib/content';
import { getTagName, getCategoryName } from '@/i18n/taxonomy';
import { useTranslations, type Lang } from '@/i18n/ui';
import { optimizeLocalImage } from '@/lib/rehype-image-size.mjs';

interface Props {
  posts: Array<{ post: CollectionEntry<'blog'>; slug: string }>;
  lang: string;
  currentPage: number;
  totalPages: number;
  /** Base href for the listing, e.g. '/' or '/en-us/' */
  baseHref: string;
}

const { posts, lang, currentPage, totalPages, baseHref } = Astro.props;
const t = useTranslations(lang as Lang);
const coverSrcBySlug = new Map<string, string | undefined>(
  await Promise.all(
    posts.map(async ({ post, slug }) => [
      slug,
      post.data.cover ? (await optimizeLocalImage(post.data.cover, { force: true })).src : undefined,
    ] as const),
  ),
);

function pageHref(n: number) {
  return n === 1 ? baseHref : `${baseHref}page/${n}/`;
}

function getPageNumbers(current: number, total: number): (number | '...')[] {
  if (total <= 7) return Array.from({ length: total }, (_, i) => i + 1);

  // Keep it compact for large totals: first + last + (current-1, current, current+1)
  const NEARBY = 1;
  const pages: (number | '...')[] = [1];

  const start = Math.max(2, current - NEARBY);
  const end = Math.min(total - 1, current + NEARBY);

  if (start > 2) pages.push('...');
  for (let i = start; i <= end; i++) {
    pages.push(i);
  }
  if (end < total - 1) pages.push('...');
  pages.push(total);

  return pages;
}

const pageNumbers = getPageNumbers(currentPage, totalPages);
---

<div class="flex flex-col gap-5">
  {posts.map(({ post, slug }) => {
    const words = countWords(post.body ?? '');
    const mins = readingMinutes(words);
    const wordStr = t('post.wordCount').replace('{count}', String(words));
    const timeStr = t('post.readingTime').replace('{min}', String(mins));
    const postHref = getPostHref(slug, lang);
    const categoryName = post.data.category ? getCategoryName(post.data.category, lang as Lang) : '';
    const coverSrc = coverSrcBySlug.get(slug);
    return (
      <div class="group relative" transition:name={`post-${slug}`}>
        <div class={`group/card flex flex-col gap-4 overflow-hidden rounded-lg bg-card py-4 text-xs/relaxed text-card-foreground shadow-fluent-sm ring-1 ring-foreground/[0.06] border-border/50 ${coverSrc ? 'pt-0' : ''}`}>
          {coverSrc && (
            <div class="h-52 w-full overflow-hidden border-b border-border/30">
              <img src={coverSrc} alt={post.data.coverAlt ?? post.data.title} class="w-full h-full object-cover" />
            </div>
          )}

          <div class="grid auto-rows-min items-start gap-1 px-4">
            <div class="flex flex-wrap items-center gap-x-1 gap-y-0.5 text-xs text-muted-foreground mb-2">
              {post.data.category && (
                <>
                  <a
                    href={getCategoryHref(post.data.category, lang)}
                    aria-label={t('aria.category').replace('{name}', categoryName)}
                    class="relative z-10 font-medium text-foreground/60 hover:text-primary transition-colors"
                  >
                    [{categoryName}]
                  </a>
                  <span class="opacity-40">·</span>
                </>
              )}
              {post.data.date && (
                <time data-local-datetime datetime={post.data.date.toISOString()} class="shrink-0">
                  {formatDateTime(post.data.date, lang)}
                </time>
              )}
              <span class="opacity-40">·</span>
              <span class="shrink-0">{wordStr}</span>
              <span class="opacity-40">·</span>
              <span class="shrink-0">{timeStr}</span>
            </div>

            <div class="font-heading text-xl font-medium leading-tight">
              <a
                href={postHref}
                aria-label={t('aria.readPost').replace('{title}', post.data.title)}
                class="hover:text-primary transition-colors after:absolute after:inset-0 after:content-['']"
              >
                {post.data.title}
              </a>
            </div>
          </div>

          {post.data.description && (
            <div class="px-4">
              <div class="line-clamp-3 text-sm text-muted-foreground">
                {post.data.description}
              </div>
            </div>
          )}

          <div class="px-4">
            <div class="flex flex-wrap items-center gap-1.5">
              {post.data.tags?.map(tag => (
                <a
                  href={getTagHref(tag, lang)}
                  aria-label={t('aria.tag').replace('{name}', getTagName(tag, lang as Lang))}
                  class="relative z-10 text-xs px-2 py-0.5 rounded-md bg-muted text-muted-foreground hover:bg-primary/10 hover:text-primary transition-colors"
                >
                  #{getTagName(tag, lang as Lang)}
                </a>
              ))}
              <a
                href={postHref}
                aria-label={t('aria.continueReading').replace('{title}', post.data.title)}
                class="relative z-10 ml-auto text-xs font-medium text-primary hover:underline transition-colors shrink-0"
              >
                {t('post.continueReading')}
              </a>
            </div>
          </div>
        </div>
      </div>
    );
  })}
</div>

{totalPages > 1 && (
  <nav class="flex items-center justify-center gap-1 mt-8" aria-label="Pagination">
    {currentPage > 1 ? (
      <a
        href={pageHref(currentPage - 1)}
        aria-label={t('pagination.prev')}
        class="px-3 py-1.5 text-sm rounded-md border border-border/50 text-muted-foreground hover:text-primary hover:border-primary/50 transition-colors"
      >
        {t('pagination.prev')}
      </a>
    ) : (
      <span class="px-3 py-1.5 text-sm rounded-md border border-border/30 text-muted-foreground/30 cursor-not-allowed select-none">
        {t('pagination.prev')}
      </span>
    )}

    {pageNumbers.map(p =>
      p === '...' ? (
        <span class="px-2 py-1.5 text-sm text-muted-foreground/50">…</span>
      ) : (
        <a
          href={pageHref(p as number)}
          aria-label={t('aria.pageNumber').replace('{page}', String(p))}
          class={`px-3 py-1.5 text-sm rounded-md border transition-colors ${
            p === currentPage
              ? 'border-primary bg-primary/10 text-primary font-medium'
              : 'border-border/50 text-muted-foreground hover:text-primary hover:border-primary/50'
          }`}
          aria-current={p === currentPage ? 'page' : undefined}
        >
          {p}
        </a>
      )
    )}

    {currentPage < totalPages ? (
      <a
        href={pageHref(currentPage + 1)}
        aria-label={t('pagination.next')}
        class="px-3 py-1.5 text-sm rounded-md border border-border/50 text-muted-foreground hover:text-primary hover:border-primary/50 transition-colors"
      >
        {t('pagination.next')}
      </a>
    ) : (
      <span class="px-3 py-1.5 text-sm rounded-md border border-border/30 text-muted-foreground/30 cursor-not-allowed select-none">
        {t('pagination.next')}
      </span>
    )}
  </nav>
)}
