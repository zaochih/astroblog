---
import type { CollectionEntry } from 'astro:content';
import { Card, CardHeader, CardTitle, CardDescription, CardContent } from '@/components/ui/card';
import { getPostHref, formatDateTime } from '@/lib/content';
import { useTranslations, type Lang } from '@/i18n/ui';

interface Props {
  posts: Array<{ post: CollectionEntry<'blog'>; slug: string }>;
  lang: string;
}

const { posts, lang } = Astro.props;
const t = useTranslations(lang as Lang);
---

<div class="flex flex-col gap-5">
  {posts.map(({ post, slug }) => (
    <div class="relative">
      <Card className="flex flex-col border-border/50">
        <CardHeader>
          <div class="flex items-center gap-3 mb-1">
            {post.data.date && (
              <time data-local-datetime datetime={post.data.date.toISOString()} class="text-xs text-muted-foreground">
                {formatDateTime(post.data.date, lang)}
              </time>
            )}
          </div>
          <CardTitle className="text-xl leading-tight">
            <a
              href={getPostHref(slug, lang)}
              aria-label={t('aria.readPost').replace('{title}', post.data.title)}
              class="hover:text-primary transition-colors after:absolute after:inset-0 after:content-['']"
            >
              {post.data.title}
            </a>
          </CardTitle>
        </CardHeader>
        {post.data.description && (
          <CardContent>
            <CardDescription className="line-clamp-2 text-sm">
              {post.data.description}
            </CardDescription>
          </CardContent>
        )}
      </Card>
    </div>
  ))}
</div>
