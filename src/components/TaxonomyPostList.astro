---
import type { CollectionEntry } from 'astro:content';
import { getPostHref, formatDateTime } from '@/lib/content';
import { useTranslations, type Lang } from '@/i18n/ui';

interface Props {
  posts: Array<{ post: CollectionEntry<'blog'>; slug: string }>;
  lang: string;
}

const { posts, lang } = Astro.props;
const t = useTranslations(lang as Lang);
---

<div class="flex flex-col gap-5">
  {posts.map(({ post, slug }) => (
    <div class="relative">
      <div class="group/card flex flex-col gap-4 overflow-hidden rounded-lg bg-card py-4 text-xs/relaxed text-card-foreground shadow-fluent-sm ring-1 ring-foreground/[0.06] border-border/50">
        <div class="grid auto-rows-min items-start gap-1 px-4">
          <div class="flex items-center gap-3 mb-1">
            {post.data.date && (
              <time data-local-datetime datetime={post.data.date.toISOString()} class="text-xs text-muted-foreground">
                {formatDateTime(post.data.date, lang)}
              </time>
            )}
          </div>
          <div class="font-heading text-xl font-medium leading-tight">
            <a
              href={getPostHref(slug, lang)}
              aria-label={t('aria.readPost').replace('{title}', post.data.title)}
              class="hover:text-primary transition-colors after:absolute after:inset-0 after:content-['']"
            >
              {post.data.title}
            </a>
          </div>
        </div>
        {post.data.description && (
          <div class="px-4">
            <div class="line-clamp-2 text-sm text-muted-foreground">
              {post.data.description}
            </div>
          </div>
        )}
      </div>
    </div>
  ))}
</div>
