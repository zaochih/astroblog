---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import Layout from '@/layouts/Layout.astro';

import { siteConfig } from '@/config';
import { useTranslations, languages, defaultLang, getLanguageName, getLangProfile, getSupportedLangs, type Lang } from '@/i18n/ui';
import { getCategoryHref, getPostHref, countWords, readingMinutes, formatDateTime, mergeWithPrimary, isPublishedEntry, localizeAndSortPosts } from '@/lib/content';
import { getCategoryName } from '@/i18n/taxonomy';
import Icon from '@/components/Icon';
import LanguageNotice from '@/components/LanguageNotice.astro';
import CrossPostNotice from '@/components/CrossPostNotice.astro';
import ExternalPostRedirect from '@/components/ExternalPostRedirect.astro';
import Comments from '@/components/Comments.astro';
import { optimizeLocalImage } from '@/lib/rehype-image-size.mjs';
import { resolveContentDescription } from '@/lib/seo';

export async function getStaticPaths() {
  // Helper: "zh/hello-world" → ["zh", "hello-world"]
  function parseEntryId(id: string) {
    const [lang, ...rest] = id.split('/');
    return { lang, slug: rest.join('/') };
  }

  const allPosts = await getCollection('blog');
  const locales = getSupportedLangs();

  // Group posts by slug across languages
  const postsBySlug = new Map<string, Record<string, CollectionEntry<'blog'>>>();
  for (const post of allPosts) {
    const { lang, slug } = parseEntryId(post.id);
    if (!postsBySlug.has(slug)) postsBySlug.set(slug, {});
    postsBySlug.get(slug)![lang] = post;
  }

  const paths: {
    params: { lang: string | undefined; slug: string };
    props: Props;
  }[] = [];

  for (const [slug, langsMap] of postsBySlug) {
    for (const lang of locales) {
      const localizedPost = langsMap[lang];
      const fallbackLang = getLangProfile(lang).fallbackLang as Lang;
      const fallbackPost = langsMap[fallbackLang];
      const post = localizedPost && isPublishedEntry(localizedPost) ? localizedPost : undefined;
      const publishedFallbackPost = fallbackLang !== lang && fallbackPost && isPublishedEntry(fallbackPost) ? fallbackPost : undefined;
      const availableLangs = Object.entries(langsMap)
        .filter(([, post]) => isPublishedEntry(post))
        .map(([lang]) => lang);
      const otherLangs = availableLangs.filter(l => l !== lang);
      const routeLang = lang === defaultLang ? undefined : lang;

      if (post) {
        paths.push({
          params: { lang: routeLang, slug },
          props: {
            post, slug, isFallback: false, currentLang: lang, fallbackLang: null, otherLangs,
            primaryData: lang !== defaultLang ? langsMap[defaultLang]?.data : undefined,
          },
        });
      } else if (publishedFallbackPost) {
        paths.push({
          params: { lang: routeLang, slug },
          props: {
            post: publishedFallbackPost, slug, isFallback: true, currentLang: lang, fallbackLang, otherLangs: availableLangs,
            primaryData: undefined,
          },
        });
      }
    }
  }

  return paths;
}

interface Props {
  post: CollectionEntry<'blog'>;
  slug: string;
  isFallback: boolean;
  currentLang: Lang;
  fallbackLang: Lang | null;
  otherLangs: string[];
  primaryData?: CollectionEntry<'blog'>['data'];
}

const { post, slug, isFallback, currentLang, fallbackLang, otherLangs, primaryData } = Astro.props;
const data = mergeWithPrimary(post.data, primaryData);
const { Content, headings } = await render(post);

const t = useTranslations(currentLang);
const wordCount = countWords(post.body ?? '');
const minutes = readingMinutes(wordCount);
const hasToc = headings.filter(h => h.depth <= 3).length > 2;
const seriesPosts = data.series
  ? localizeAndSortPosts(await getCollection('blog'), currentLang)
      .filter(({ post: seriesPost }) => seriesPost.data.series === data.series)
      .sort((a, b) => {
        const orderA = a.post.data.seriesOrder ?? Number.MAX_SAFE_INTEGER;
        const orderB = b.post.data.seriesOrder ?? Number.MAX_SAFE_INTEGER;
        if (orderA !== orderB) return orderA - orderB;
        return (a.post.data.date?.valueOf() ?? 0) - (b.post.data.date?.valueOf() ?? 0);
      })
  : [];
const seriesIndex = seriesPosts.findIndex(seriesPost => seriesPost.slug === slug);
const previousSeriesPost = seriesIndex > 0 ? seriesPosts[seriesIndex - 1] : null;
const nextSeriesPost = seriesIndex >= 0 && seriesIndex < seriesPosts.length - 1 ? seriesPosts[seriesIndex + 1] : null;
const coverImage = data.cover ? (await optimizeLocalImage(data.cover, { force: true })).src : undefined;
const pageDescription = resolveContentDescription({
  frontmatterDescription: data.description,
  body: post.body,
  title: data.title,
  lang: currentLang,
  kind: 'article',
});

const fallbackLangName = isFallback && fallbackLang ? getLanguageName(fallbackLang, currentLang) : '';
const fallbackDesc = t('alert.fallback.desc').replace('{lang}', fallbackLangName);

const getLangLink = (l: string) =>
  l === defaultLang ? `/post/${slug}` : `/${l}/post/${slug}`;
const otherLanguageLinks = otherLangs.map(l => ({
  href: getLangLink(l),
  label: languages[l as Lang],
  lang: l,
  ariaLabel: t('aria.switchLanguage').replace('{lang}', getLanguageName(l, currentLang)),
}));

const homeHref = currentLang === defaultLang ? '/' : `/${currentLang}/`;
---

{data.redirectUrl ? (
  <ExternalPostRedirect
    title={data.title}
    description={pageDescription}
    lang={currentLang}
    redirectUrl={data.redirectUrl}
  />
) : (
<Layout
  title={`${data.title} | ${siteConfig.name}`}
  description={pageDescription}
  lang={currentLang}
  image={coverImage}
  canonicalUrl={data.canonicalUrl}
  math={data.math}
  hideHeaderOnScroll
  searchable
>
  <div class={hasToc ? "max-w-5xl mx-auto mt-6 sm:mt-10 xl:grid xl:grid-cols-[1fr_220px] xl:gap-10 xl:items-start" : "max-w-3xl mx-auto mt-6 sm:mt-10"}>
  <article transition:name={`post-${slug}`} class="min-w-0">

    <a href={homeHref} aria-label={t('aria.postBack')} class="group/button inline-flex shrink-0 items-center justify-center rounded-md text-xs/relaxed font-medium whitespace-nowrap transition-all hover:bg-muted hover:text-foreground mb-6 hover:bg-accent/50 -ml-4 h-7 gap-1 px-2">
      {t('post.back')}
    </a>

    <header class="mb-6 text-center">
      <h1 class="text-3xl font-extrabold tracking-tight text-foreground mb-4 leading-tight sm:text-4xl">
        {data.title}
      </h1>
      <div class="flex flex-wrap items-center justify-center gap-x-4 gap-y-1 text-xs text-muted-foreground">
        {data.date && (
          <span class="inline-flex items-center gap-1">
            <Icon name="calendar" className="size-3.5" size={14} />
            <time data-local-datetime datetime={data.date.toISOString()}>{formatDateTime(data.date, currentLang)}</time>
          </span>
        )}
        {data.category && (
          <a
            href={getCategoryHref(data.category, currentLang)}
            aria-label={t('aria.category').replace('{name}', getCategoryName(data.category, currentLang))}
            class="inline-flex items-center gap-1 hover:text-primary transition-colors"
          >
            <Icon name="folder" className="size-3.5" size={14} />
            {getCategoryName(data.category, currentLang)}
          </a>
        )}
        <span class="inline-flex items-center gap-1">
          <Icon name="book" className="size-3.5" size={14} />
          {t('post.wordCount').replace('{count}', String(wordCount))}
        </span>
        <span class="inline-flex items-center gap-1">
          <Icon name="clock" className="size-3.5" size={14} />
          {t('post.readingTime').replace('{min}', String(minutes))}
        </span>
      </div>
    </header>

    {hasToc && (
      <details class="animated-details mb-4 rounded-lg border border-border/50 bg-card p-4 xl:hidden">
        <summary class="cursor-pointer select-none text-xs font-semibold uppercase tracking-wider text-foreground/70">
          {t('post.toc')}
        </summary>
        <div class="details-content">
          <nav class="mt-3" aria-label={t('aria.toc')}>
            <ul class="space-y-1.5">
              {headings.filter(h => h.depth <= 3 && h.slug !== 'footnote-label').map(h => (
                <li>
                  <a
                    href={`#${h.slug}`}
                    aria-label={t('aria.tocJump').replace('{title}', h.text)}
                    class={`block text-xs leading-relaxed text-muted-foreground transition-colors hover:text-primary ${h.depth >= 3 ? 'pl-3' : ''}`}
                  >
                    {h.text}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </div>
      </details>
    )}

    {isFallback && (
      <LanguageNotice type="fallback" title={t('alert.fallback.title')} message={fallbackDesc} />
    )}

    {!isFallback && otherLangs.length > 0 && (
      <LanguageNotice type="available" availableLabel={t('alert.available')} languages={otherLanguageLinks} />
    )}

    {!isFallback && currentLang === 'zh-cn' && data.weixinName && data.weixinLink && (
      <CrossPostNotice platform="weixin" name={data.weixinName} href={data.weixinLink} lang={currentLang} />
    )}
    {!isFallback && data.msftLink && (
      <CrossPostNotice platform="msft" href={data.msftLink} lang={currentLang} />
    )}

    <div class="prose dark:prose-invert max-w-none prose-a:text-primary prose-a:no-underline">
      <Content />
    </div>

    {(previousSeriesPost || nextSeriesPost) && (
      <nav class="mt-12 grid gap-3 border-t border-border/50 pt-6 sm:grid-cols-2" aria-label={t('series.inSeries')}>
        {previousSeriesPost ? (
          <a
            href={getPostHref(previousSeriesPost.slug, currentLang)}
            aria-label={t('aria.seriesPrevious').replace('{title}', previousSeriesPost.post.data.title)}
            class="rounded-lg border border-border/50 p-4 text-sm transition-colors hover:border-primary/50 hover:text-primary"
          >
            <span class="block text-xs text-muted-foreground">{t('series.previous')}</span>
            <span class="mt-1 block font-medium">{previousSeriesPost.post.data.title}</span>
          </a>
        ) : (
          <span></span>
        )}
        {nextSeriesPost && (
          <a
            href={getPostHref(nextSeriesPost.slug, currentLang)}
            aria-label={t('aria.seriesNext').replace('{title}', nextSeriesPost.post.data.title)}
            class="rounded-lg border border-border/50 p-4 text-right text-sm transition-colors hover:border-primary/50 hover:text-primary"
          >
            <span class="block text-xs text-muted-foreground">{t('series.next')}</span>
            <span class="mt-1 block font-medium">{nextSeriesPost.post.data.title}</span>
          </a>
        )}
      </nav>
    )}

    <Comments lang={currentLang} term={`posts/${slug}`} enabled={data.comments !== false} />

  </article>

  {hasToc && (
    <aside class="hidden xl:block sticky top-[var(--toc-sticky-top)] self-start transition-[top] duration-200 ease-out">
      <div class="rounded-lg border border-border/50 bg-card p-4">
        <p class="text-xs font-semibold text-foreground/70 uppercase tracking-wider mb-3">
          {t('post.toc')}
        </p>
        <nav aria-label={t('aria.toc')}>
          <ul class="space-y-1.5">
            {headings.filter(h => h.depth <= 3 && h.slug !== 'footnote-label').map(h => (
              <li>
                <a
                  href={`#${h.slug}`}
                  aria-label={t('aria.tocJump').replace('{title}', h.text)}
                  class={`block text-xs text-muted-foreground hover:text-primary transition-colors leading-relaxed ${h.depth >= 3 ? 'pl-3' : ''}`}
                >
                  {h.text}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>

      {/* Scroll progress + back-to-top */}
      <div class="mt-3 flex items-center justify-between px-1">
        <div class="flex items-center gap-1.5">
          <div class="relative size-5 shrink-0" role="img" aria-label={t('aria.scrollProgress')}>
            <svg class="w-full h-full -rotate-90" viewBox="0 0 36 36" aria-hidden="true">
              <circle cx="18" cy="18" r="15.9155" fill="none" stroke="currentColor"
                stroke-width="4" class="text-border opacity-60" />
              <circle id="toc-progress-ring" cx="18" cy="18" r="15.9155" fill="none"
                stroke="currentColor" stroke-width="4" class="text-primary"
                stroke-dasharray="100" stroke-dashoffset="100" stroke-linecap="round"
                style="transition: stroke-dashoffset 0.2s ease;" />
            </svg>
          </div>
          <span id="toc-progress-text" class="text-[10px] font-medium text-muted-foreground tabular-nums">
            0%
          </span>
        </div>

        <button id="back-to-top"
          aria-label={t('aria.backToTop')}
          class="opacity-0 pointer-events-none transition-opacity duration-300 inline-flex shrink-0 items-center justify-center rounded-md text-xs/relaxed font-medium whitespace-nowrap transition-all hover:bg-muted hover:text-foreground h-7 px-2 gap-1">
          <Icon name="arrowUp" className="size-3" size={12} strokeWidth={2.5} />
          Top
        </button>
      </div>
    </aside>
  )}

  <script>
    function initScrollFeatures() {
      const ring = document.getElementById('toc-progress-ring');
      const text = document.getElementById('toc-progress-text');
      const btn = document.getElementById('back-to-top');

      if (!ring && !btn) return;

      let docHeight = 0;
      const refreshMetrics = () => {
        docHeight = document.documentElement.scrollHeight - window.innerHeight;
      };

      const update = () => {
        const scrollTop = window.scrollY;
        const pct = docHeight > 0 ? Math.min(100, Math.round((scrollTop / docHeight) * 100)) : 0;

        if (ring) ring.style.strokeDashoffset = String(100 - pct);
        if (text) text.textContent = pct + '%';

        if (btn) {
          if (scrollTop > 200) {
            btn.classList.remove('opacity-0', 'pointer-events-none');
            btn.classList.add('opacity-100');
          } else {
            btn.classList.add('opacity-0', 'pointer-events-none');
            btn.classList.remove('opacity-100');
          }
        }
      };

      refreshMetrics();
      window.addEventListener('scroll', update, { passive: true });
      window.addEventListener('resize', () => {
        refreshMetrics();
        update();
      }, { passive: true });
      update();

      btn?.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    }

    initScrollFeatures();
    document.addEventListener('astro:page-load', initScrollFeatures);
  </script>

  </div>
</Layout>
)}
