---
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import { siteConfig } from '@/config';
import { useTranslations, defaultLang, type Lang } from '@/i18n/ui';
import { localizeAndSortPosts } from '@/lib/content';
import PostFeed from '@/components/PostFeed.astro';
import BlogSidebar from '@/components/BlogSidebar.astro';
import { describeListingPage } from '@/lib/seo';

const PAGE_SIZE = 10;

export async function getStaticPaths() {
  const PAGE_SIZE = 10;
  const { getCollection } = await import('astro:content');
  const { localizeAndSortPosts } = await import('@/lib/content');
  const { languages, defaultLang } = await import('@/i18n/ui');

  const allPosts = await getCollection('blog');
  const paths = [];

  for (const lang of Object.keys(languages)) {
    const localizedPosts = localizeAndSortPosts(allPosts, lang);
    const totalPages = Math.ceil(localizedPosts.length / PAGE_SIZE);
    for (let page = 2; page <= totalPages; page++) {
      paths.push({
        params: {
          lang: lang === defaultLang ? undefined : lang,
          page: String(page),
        },
        props: { lang, page, totalPages },
      });
    }
  }

  return paths;
}

const { lang, page, totalPages } = Astro.props as { lang: string; page: number; totalPages: number };
const t = useTranslations(lang as Lang);

const allPosts = await getCollection('blog');
const localizedPosts = localizeAndSortPosts(allPosts, lang);

const pagedPosts = localizedPosts.slice((page - 1) * PAGE_SIZE, page * PAGE_SIZE);
const baseHref = lang === defaultLang ? '/' : `/${lang}/`;
---

<Layout
  title={`${t('nav.home')} — ${t('archive.title')} ${page} | ${siteConfig.name}`}
  description={describeListingPage({ kind: 'paginatedArticles', lang, page })}
  lang={lang}
>
  <div class="lg:grid lg:grid-cols-[220px_1fr_220px] lg:gap-8">

    <BlogSidebar posts={localizedPosts} lang={lang} side="left" />

    {/* Center — post feed */}
    <div>
      <PostFeed
        posts={pagedPosts}
        lang={lang}
        currentPage={page}
        totalPages={totalPages}
        baseHref={baseHref}
      />
    </div>

    <BlogSidebar posts={localizedPosts} lang={lang} side="right" />

  </div>
</Layout>
