---
import Layout from '@/layouts/Layout.astro';
import { siteConfig } from '@/config';
import { useTranslations, languages, defaultLang, type Lang } from '@/i18n/ui';
import yaml from 'js-yaml';
import friendsRaw from '@/data/friends.yaml?raw';
import HugeIcon from '@/components/HugeIcon';
import { pinyin } from 'pinyin-pro';
import { describeListingPage } from '@/lib/seo';

export async function getStaticPaths() {
  return Object.keys(languages).map(lang => ({
    params: { lang: lang === defaultLang ? undefined : lang },
    props: { lang },
  }));
}

const { lang } = Astro.props as { lang: string };
const t = useTranslations(lang as Lang);

interface FriendLink {
  icon: string;
  url: string;
}

interface FriendLocale {
  name?: string;
  description?: string;
  url?: string;
  links?: FriendLink[];
  backgroundIcon?: string;
}

type FriendTime = string | Date;

interface Friend {
  name: string;
  description: string;
  url: string;
  backgroundIcon?: string;
  pinned?: boolean;
  sponsored?: boolean;
  referral?: boolean;
  startAt?: FriendTime;
  endAt?: FriendTime;
  links?: FriendLink[];
  i18n?: Partial<Record<Lang, FriendLocale>>;
}

const friends = yaml.load(friendsRaw) as Friend[];
const buildTime = Date.now();

function localizeFriend(friend: Friend, lang: Lang): Friend {
  const localized = friend.i18n?.[lang];
  if (!localized) return friend;

  return {
    ...friend,
    name: localized.name ?? friend.name,
    description: localized.description ?? friend.description,
    url: localized.url ?? friend.url,
    links: localized.links ?? friend.links,
    backgroundIcon: localized.backgroundIcon ?? friend.backgroundIcon,
    i18n: friend.i18n,
  };
}

function parseFriendTime(value?: FriendTime): number | undefined {
  if (!value) return undefined;
  if (value instanceof Date) {
    const time = value.getTime();
    return Number.isNaN(time) ? undefined : time;
  }
  const time = Date.parse(value);
  return Number.isNaN(time) ? undefined : time;
}

function getFriendTimeAttribute(value?: FriendTime): string | undefined {
  if (!value) return undefined;
  if (value instanceof Date) {
    const time = value.getTime();
    return Number.isNaN(time) ? undefined : value.toISOString();
  }
  return value;
}

function isTimedFriend(friend: Friend): boolean {
  return Boolean((friend.sponsored || friend.referral) && (friend.startAt || friend.endAt));
}

function isFriendActiveAt(friend: Friend, now: number): boolean {
  if (!isTimedFriend(friend)) return true;
  const startAt = parseFriendTime(friend.startAt);
  const endAt = parseFriendTime(friend.endAt);
  return (startAt === undefined || now >= startAt) && (endAt === undefined || now < endAt);
}

function shouldIncludeFriendAtBuild(friend: Friend, now: number): boolean {
  if (!isTimedFriend(friend)) return true;
  const endAt = parseFriendTime(friend.endAt);
  return endAt === undefined || now < endAt;
}

function getFriendSortKey(friend: Friend): string {
  return pinyin(friend.name, {
    toneType: 'none',
    type: 'array',
    nonZh: 'consecutive',
  }).join(' ').toLocaleLowerCase();
}

const localizedFriends = friends.map((friend, index) => ({
  friend: localizeFriend(friend, lang as Lang),
  index,
})).filter(({ friend }) => shouldIncludeFriendAtBuild(friend, buildTime));

const regularFriends = localizedFriends
  .filter(({ friend }) => !friend.sponsored && !friend.referral)
  .sort((a, b) => {
    if (a.friend.pinned !== b.friend.pinned) return a.friend.pinned ? -1 : 1;
    const nameOrder = getFriendSortKey(a.friend).localeCompare(getFriendSortKey(b.friend), lang, {
      sensitivity: 'base',
      numeric: true,
    });
    if (nameOrder !== 0) return nameOrder;
    return a.index - b.index;
  })
  .map(({ friend }) => friend);

const sponsoredFriends = localizedFriends
  .filter(({ friend }) => friend.sponsored)
  .map(({ friend }) => friend);

const referralFriends = localizedFriends
  .filter(({ friend }) => friend.referral)
  .map(({ friend }) => friend);

const sortedFriends = [...sponsoredFriends, ...regularFriends, ...referralFriends];
---

<Layout
  title={`${t('friends.title')} | ${siteConfig.name}`}
  description={describeListingPage({ kind: 'friends', lang })}
  lang={lang}
>
  <div class="max-w-4xl mx-auto">
    <h1 class="text-3xl font-bold tracking-tight text-foreground mb-6">{t('friends.title')}</h1>

    {sortedFriends.length === 0 ? (
      <div class="text-center py-20 text-muted-foreground border border-dashed border-border/60 rounded-md">
        {t('friends.empty')}
      </div>
    ) : (
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {sortedFriends.map(friend => {
          const rel = friend.sponsored ? 'noopener noreferrer sponsored' : 'noopener noreferrer';
          const isTimeLimited = isTimedFriend(friend);
          const isActiveAtBuild = isFriendActiveAt(friend, buildTime);
          const cardClass = friend.sponsored
            ? 'border-amber-300/55 bg-[#120906] shadow-[0_0_0_1px_rgba(252,211,77,0.16),0_10px_30px_rgba(217,119,6,0.16)] dark:border-amber-300/55 dark:bg-amber-950/20 dark:shadow-[0_0_0_1px_rgba(252,211,77,0.16),0_10px_30px_rgba(217,119,6,0.16)]'
            : friend.referral
              ? 'border-sky-300/55 bg-sky-50/45 shadow-[0_0_0_1px_rgba(125,211,252,0.16),0_10px_30px_rgba(14,165,233,0.16)] dark:border-sky-300/55 dark:bg-sky-950/20 dark:shadow-[0_0_0_1px_rgba(125,211,252,0.16),0_10px_30px_rgba(14,165,233,0.16)]'
              : 'border-border/50 bg-card';
          const titleClass = friend.sponsored
            ? 'text-amber-200'
            : friend.referral
              ? 'text-sky-600 dark:text-sky-200'
              : 'text-primary';
          const descriptionClass = friend.sponsored
            ? 'text-zinc-300/80 dark:text-muted-foreground'
            : friend.referral
              ? 'text-muted-foreground'
              : 'text-muted-foreground';
          const iconClass = friend.sponsored
            ? 'text-zinc-300/70 hover:text-amber-200 dark:text-muted-foreground dark:hover:text-amber-200'
            : friend.referral
              ? 'text-muted-foreground hover:text-sky-600 dark:hover:text-sky-200'
              : 'text-muted-foreground hover:text-primary';
          const arrowClass = friend.sponsored
            ? 'text-zinc-300/40 hover:text-amber-200 dark:text-muted-foreground/50 dark:hover:text-amber-200'
            : friend.referral
              ? 'text-muted-foreground/50 hover:text-sky-600 dark:hover:text-sky-200'
              : 'text-muted-foreground/50 hover:text-primary';
          return (
          <div
            class={`group relative isolate flex min-h-[140px] flex-col justify-between overflow-hidden rounded-lg border p-5 transition-colors ${isTimeLimited ? isActiveAtBuild ? 'friend-card-pending' : 'friend-card-waiting' : ''} ${cardClass}`}
            data-friend-glow-card={friend.backgroundIcon ? true : undefined}
            data-friend-time-limited={isTimeLimited ? true : undefined}
            data-friend-start-at={isTimeLimited ? getFriendTimeAttribute(friend.startAt) : undefined}
            data-friend-end-at={isTimeLimited ? getFriendTimeAttribute(friend.endAt) : undefined}
          >
            {friend.backgroundIcon && (
              <div class="friend-glow" aria-hidden="true">
                <img src={friend.backgroundIcon} alt="" loading="lazy" decoding="async" />
              </div>
            )}

            <a
              href={friend.url}
              target="_blank"
              rel={rel}
              class="absolute inset-0 z-10"
              aria-label={t('aria.friendSite').replace('{name}', friend.name)}
            />

            {/* Name */}
            <div class="friend-card-main relative z-20 pointer-events-none">
              <div class="mb-1.5 flex flex-wrap items-center gap-2">
                <h2 class={`friend-card-title text-base font-semibold ${titleClass}`}>{friend.name}</h2>
                {friend.pinned && (
                  <span class="rounded-md border border-border bg-background px-1.5 py-0.5 text-[10px] font-medium text-foreground">
                    {t('friends.pinned')}
                  </span>
                )}
                {friend.sponsored && (
                  <span class="rounded-md border border-amber-300/35 bg-amber-300/15 px-1.5 py-0.5 text-[10px] font-semibold text-amber-100 shadow-sm shadow-amber-500/10">
                    {t('friends.sponsored')}
                  </span>
                )}
                {friend.referral && (
                  <span class="rounded-md border border-sky-300/45 bg-sky-100/70 px-1.5 py-0.5 text-[10px] font-semibold text-sky-700 shadow-sm shadow-sky-500/10 dark:border-sky-300/35 dark:bg-sky-300/15 dark:text-sky-100">
                    {t('friends.referral')}
                  </span>
                )}
                {isTimeLimited && (
                  <span class="rounded-md border border-mist-300/35 bg-mist-300/15 px-1.5 py-0.5 text-[10px] font-semibold text-mist-100 shadow-sm shadow-mist-500/10">
                    {t('friends.timeLimited')}
                  </span>
                )}
              </div>
              <p class={`text-sm leading-relaxed ${descriptionClass}`}>{friend.description}</p>
            </div>

            {/* Bottom row: sub-link icons left, arrow right */}
            <div class="relative z-20 flex items-center justify-between mt-4 pointer-events-none">
              <div class="flex items-center gap-2">
                {friend.links?.map(link => (
                  <a
                    href={link.url}
                    target="_blank"
                    rel={rel}
                    class={`relative z-30 pointer-events-auto transition-colors ${iconClass}`}
                    aria-label={t('aria.friendLink').replace('{name}', friend.name).replace('{type}', link.icon)}
                    title={link.icon}
                  >
                    <HugeIcon name={link.icon} className="size-4" size={16} />
                  </a>
                ))}
              </div>
              <span class={`transition-colors ${arrowClass}`} aria-hidden="true">
                <HugeIcon name="arrowRight" className="size-5" size={20} />
              </span>
            </div>
          </div>
        )})}
      </div>
    )}
  </div>
</Layout>

<style>
  /* Pointer glow adapted from Jhey Tompkins' CodePen: https://codepen.io/jh3y/pen/WbwZaNa */
  [data-friend-glow-card] {
    --friend-glow-x: 0;
    --friend-glow-y: 0;
  }

  @media (pointer: coarse) {
    [data-friend-glow-card] {
      touch-action: none;
    }
  }

  .friend-card-title {
    display: inline;
    background-image: linear-gradient(currentColor, currentColor);
    background-position: 0 100%;
    background-repeat: no-repeat;
    background-size: 0 1px;
    box-decoration-break: clone;
    -webkit-box-decoration-break: clone;
    transition: background-size 180ms ease;
  }

  .group:is(:hover, :focus-within) .friend-card-title {
    background-size: 100% 1px;
  }

  .friend-card-retired {
    display: none;
  }

  .friend-card-pending:not(.friend-card-revealed),
  .friend-card-waiting:not(.friend-card-revealed) {
    pointer-events: none;
  }

  .friend-card-pending:not(.friend-card-revealed) .friend-card-main,
  .friend-card-waiting:not(.friend-card-revealed) .friend-card-main,
  .friend-card-pending:not(.friend-card-revealed) .friend-glow,
  .friend-card-waiting:not(.friend-card-revealed) .friend-glow {
    opacity: 0;
  }

  .friend-card-pending:not(.friend-card-revealed)::before,
  .friend-card-waiting:not(.friend-card-revealed)::before {
    --friend-card-skeleton: rgba(245, 158, 11, 0.18);
    --friend-card-skeleton-strong: rgba(252, 211, 77, 0.28);
    content: "";
    position: absolute;
    inset: 1.25rem;
    z-index: 30;
    background-image:
      linear-gradient(var(--friend-card-skeleton-strong), var(--friend-card-skeleton-strong)),
      linear-gradient(var(--friend-card-skeleton), var(--friend-card-skeleton)),
      linear-gradient(var(--friend-card-skeleton), var(--friend-card-skeleton));
    background-position:
      0 0,
      0 1.9rem,
      0 3.15rem;
    background-repeat: no-repeat;
    background-size:
      min(12rem, 56%) 1rem,
      min(8rem, 38%) 0.65rem,
      78% 0.65rem;
  }

  .friend-glow {
    position: absolute;
    inset: -34%;
    z-index: 0;
    display: grid;
    place-items: center;
    pointer-events: none;
    opacity: 0.16;
    transform: translate(
      calc(var(--friend-glow-x) * 18%),
      calc(var(--friend-glow-y) * 18%)
    );
    transition:
      opacity 180ms ease,
      transform 220ms ease-out;
  }

  [data-friend-glow-card]:is(:hover, :focus-within) .friend-glow {
    opacity: 0.28;
  }

  .friend-glow img {
    width: min(46%, 9rem);
    aspect-ratio: 1;
    object-fit: contain;
    filter: blur(24px) saturate(1.8) brightness(1.12);
    opacity: 0.92;
    transform: scaleX(2.9) scaleY(2.2);
  }

  @media (prefers-reduced-motion: reduce) {
    .friend-glow {
      transform: none;
      transition: opacity 180ms ease;
    }
  }
</style>

<script>
  (() => {
    interface FriendGlowController {
      init: () => void;
    }

    interface FriendGlowWindow extends Window {
      __lczFriendGlow?: FriendGlowController;
    }

    type FriendGlowPosition = {
      x: number;
      y: number;
    };

    type FriendGlowTouchState = {
      identifier: number;
      startX: number;
      startY: number;
      cardTop: number;
      cardBottom: number;
      lastY: number;
      scrolling: boolean;
    };

    const friendGlowWindow = window as FriendGlowWindow;
    const existing = friendGlowWindow.__lczFriendGlow;
    if (existing) {
      existing.init();
      return;
    }

    const motionQuery = window.matchMedia('(prefers-reduced-motion: reduce)');
    const touchScrollEdgePadding = 12;
    const clamp = (value: number, min: number, max: number) => Math.min(Math.max(value, min), max);
    const parseTime = (value: string | undefined) => {
      if (!value) return undefined;
      const time = Date.parse(value);
      return Number.isNaN(time) ? undefined : time;
    };

    const isTimeLimitedCardActive = (card: HTMLElement, now: number) => {
      const startAt = parseTime(card.dataset.friendStartAt);
      const endAt = parseTime(card.dataset.friendEndAt);
      return (startAt === undefined || now >= startAt) && (endAt === undefined || now < endAt);
    };

    const revealTimeLimitedCards = () => {
      if (new URLSearchParams(window.location.search).has('friendSkeleton')) return;
      const now = Date.now();
      document.querySelectorAll<HTMLElement>('[data-friend-time-limited]').forEach(card => {
        const isActive = isTimeLimitedCardActive(card, now);
        card.classList.toggle('friend-card-revealed', isActive);
        card.classList.toggle('friend-card-retired', !isActive);
      });
    };

    const state = {
      boundCards: new WeakSet<HTMLElement>(),
      pending: new Map<HTMLElement, FriendGlowPosition>(),
      touchState: new WeakMap<HTMLElement, FriendGlowTouchState>(),
      suppressClick: new WeakSet<HTMLElement>(),
      frame: 0,
    };

    const flush = () => {
      state.pending.forEach(({ x, y }, card) => {
        card.style.setProperty('--friend-glow-x', x.toFixed(3));
        card.style.setProperty('--friend-glow-y', y.toFixed(3));
      });
      state.pending.clear();
      state.frame = 0;
    };

    const schedule = (card: HTMLElement, x: number, y: number) => {
      state.pending.set(card, { x, y });
      if (state.frame === 0) {
        state.frame = window.requestAnimationFrame(flush);
      }
    };

    const scheduleFromClientPoint = (card: HTMLElement, clientX: number, clientY: number) => {
      const rect = card.getBoundingClientRect();
      const x = (clientX - (rect.left + rect.width / 2)) / (rect.width / 2);
      const y = (clientY - (rect.top + rect.height / 2)) / (rect.height / 2);

      schedule(card, clamp(x, -1, 1), clamp(y, -1, 1));
    };

    const scheduleFromPointer = (card: HTMLElement, event: PointerEvent) => {
      scheduleFromClientPoint(card, event.clientX, event.clientY);
    };

    const releasePointerCapture = (card: HTMLElement, pointerId: number) => {
      if (card.hasPointerCapture(pointerId)) {
        card.releasePointerCapture(pointerId);
      }
    };

    const finishPointer = (card: HTMLElement, event: PointerEvent) => {
      releasePointerCapture(card, event.pointerId);
      schedule(card, 0, 0);
    };

    const getChangedTouch = (event: TouchEvent) => event.changedTouches.item(0);

    const getTrackedTouch = (event: TouchEvent, touch: FriendGlowTouchState) => {
      for (let index = 0; index < event.touches.length; index += 1) {
        const candidate = event.touches.item(index);
        if (candidate?.identifier === touch.identifier) return candidate;
      }
      return undefined;
    };

    const isTouchPastCardY = (touch: Touch, touchState: FriendGlowTouchState) => (
      touch.clientY < touchState.cardTop - touchScrollEdgePadding
      || touch.clientY > touchState.cardBottom + touchScrollEdgePadding
    );

    const finishTrackedTouch = (card: HTMLElement) => {
      const touch = state.touchState.get(card);
      state.touchState.delete(card);
      schedule(card, 0, 0);

      if (!touch?.scrolling) return;
      state.suppressClick.add(card);
      window.setTimeout(() => state.suppressClick.delete(card), 450);
    };

    const bindCard = (card: HTMLElement) => {
      if (state.boundCards.has(card)) return;
      state.boundCards.add(card);

      card.addEventListener('pointermove', (event: PointerEvent) => {
        if (event.pointerType === 'touch') return;
        scheduleFromPointer(card, event);
      });

      card.addEventListener('pointerdown', (event: PointerEvent) => {
        if (event.pointerType === 'touch') return;
        if (event.pointerType !== 'mouse') {
          card.setPointerCapture(event.pointerId);
        }
        scheduleFromPointer(card, event);
      });

      card.addEventListener('touchstart', (event: TouchEvent) => {
        if (event.touches.length !== 1) return;
        const touch = getChangedTouch(event);
        if (!touch) return;

        const rect = card.getBoundingClientRect();
        state.touchState.set(card, {
          identifier: touch.identifier,
          startX: touch.clientX,
          startY: touch.clientY,
          cardTop: rect.top,
          cardBottom: rect.bottom,
          lastY: touch.clientY,
          scrolling: false,
        });
        scheduleFromClientPoint(card, touch.clientX, touch.clientY);
      }, { passive: true });

      card.addEventListener('touchmove', (event: TouchEvent) => {
        const touchState = state.touchState.get(card);
        if (!touchState) return;

        const touch = getTrackedTouch(event, touchState);
        if (!touch) return;

        if (!touchState.scrolling && isTouchPastCardY(touch, touchState)) {
          touchState.scrolling = true;
          touchState.lastY = touch.clientY;
          schedule(card, 0, 0);
        }

        if (event.cancelable) {
          event.preventDefault();
        }

        if (touchState.scrolling) {
          const scrollDelta = touch.clientY - touchState.lastY;
          touchState.lastY = touch.clientY;
          window.scrollBy(0, -scrollDelta);
          return;
        }

        scheduleFromClientPoint(card, touch.clientX, touch.clientY);
      }, { passive: false });

      card.addEventListener('touchend', () => {
        finishTrackedTouch(card);
      }, { passive: true });

      card.addEventListener('touchcancel', () => {
        finishTrackedTouch(card);
      }, { passive: true });

      card.addEventListener('pointerleave', () => {
        schedule(card, 0, 0);
      });

      card.addEventListener('pointerup', (event: PointerEvent) => {
        if (event.pointerType === 'touch') return;
        finishPointer(card, event);
      });

      card.addEventListener('pointercancel', (event: PointerEvent) => {
        if (event.pointerType === 'touch') return;
        finishPointer(card, event);
      });

      card.addEventListener('click', (event: MouseEvent) => {
        if (!state.suppressClick.has(card)) {
          return;
        }
        event.preventDefault();
        event.stopPropagation();
        state.suppressClick.delete(card);
      }, true);
    };

    const init = () => {
      revealTimeLimitedCards();
      if (motionQuery.matches) return;
      document.querySelectorAll<HTMLElement>('[data-friend-glow-card]').forEach(bindCard);
    };

    document.addEventListener('astro:page-load', init);
    document.addEventListener('astro:after-swap', () => requestAnimationFrame(init));

    friendGlowWindow.__lczFriendGlow = { init };
    init();
  })();
</script>
