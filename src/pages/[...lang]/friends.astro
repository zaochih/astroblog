---
import Layout from '@/layouts/Layout.astro';
import { siteConfig } from '@/config';
import { useTranslations, languages, defaultLang, type Lang } from '@/i18n/ui';
import yaml from 'js-yaml';
import friendsRaw from '@/data/friends.yaml?raw';
import HugeIcon from '@/components/HugeIcon';
import { pinyin } from 'pinyin-pro';

export async function getStaticPaths() {
  return Object.keys(languages).map(lang => ({
    params: { lang: lang === defaultLang ? undefined : lang },
    props: { lang },
  }));
}

const { lang } = Astro.props as { lang: string };
const t = useTranslations(lang as Lang);

interface FriendLink {
  icon: string;
  url: string;
}

interface FriendLocale {
  name?: string;
  description?: string;
  url?: string;
  links?: FriendLink[];
  backgroundIcon?: string;
}

interface Friend {
  name: string;
  description: string;
  url: string;
  backgroundIcon?: string;
  pinned?: boolean;
  sponsored?: boolean;
  referral?: boolean;
  links?: FriendLink[];
  i18n?: Partial<Record<Lang, FriendLocale>>;
}

const friends = yaml.load(friendsRaw) as Friend[];
function localizeFriend(friend: Friend, lang: Lang): Friend {
  const localized = friend.i18n?.[lang];
  if (!localized) return friend;

  return {
    ...friend,
    name: localized.name ?? friend.name,
    description: localized.description ?? friend.description,
    url: localized.url ?? friend.url,
    links: localized.links ?? friend.links,
    backgroundIcon: localized.backgroundIcon ?? friend.backgroundIcon,
    i18n: friend.i18n,
  };
}

function getFriendSortKey(friend: Friend): string {
  return pinyin(friend.name, {
    toneType: 'none',
    type: 'array',
    nonZh: 'consecutive',
  }).join(' ').toLocaleLowerCase();
}

const localizedFriends = friends.map((friend, index) => ({
  friend: localizeFriend(friend, lang as Lang),
  index,
}));

const regularFriends = localizedFriends
  .filter(({ friend }) => !friend.sponsored && !friend.referral)
  .sort((a, b) => {
    if (a.friend.pinned !== b.friend.pinned) return a.friend.pinned ? -1 : 1;
    const nameOrder = getFriendSortKey(a.friend).localeCompare(getFriendSortKey(b.friend), lang, {
      sensitivity: 'base',
      numeric: true,
    });
    if (nameOrder !== 0) return nameOrder;
    return a.index - b.index;
  })
  .map(({ friend }) => friend);

const sponsoredFriends = localizedFriends
  .filter(({ friend }) => friend.sponsored)
  .map(({ friend }) => friend);

const referralFriends = localizedFriends
  .filter(({ friend }) => friend.referral)
  .map(({ friend }) => friend);

const sortedFriends = [...sponsoredFriends, ...regularFriends, ...referralFriends];
---

<Layout title={`${t('friends.title')} | ${siteConfig.name}`} lang={lang}>
  <div class="max-w-4xl mx-auto">
    <h1 class="text-3xl font-bold tracking-tight text-foreground mb-6">{t('friends.title')}</h1>

    {friends.length === 0 ? (
      <div class="text-center py-20 text-muted-foreground border border-dashed border-border/60 rounded-md">
        {t('friends.empty')}
      </div>
    ) : (
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {sortedFriends.map(friend => {
          const rel = friend.sponsored ? 'noopener noreferrer sponsored' : 'noopener noreferrer';
          const cardClass = friend.sponsored
            ? 'border-amber-300/55 bg-[#120906] shadow-[0_0_0_1px_rgba(252,211,77,0.16),0_10px_30px_rgba(217,119,6,0.16)] dark:border-amber-300/55 dark:bg-amber-950/20 dark:shadow-[0_0_0_1px_rgba(252,211,77,0.16),0_10px_30px_rgba(217,119,6,0.16)]'
            : friend.referral
              ? 'border-sky-300/55 bg-sky-50/45 shadow-[0_0_0_1px_rgba(125,211,252,0.16),0_10px_30px_rgba(14,165,233,0.16)] dark:border-sky-300/55 dark:bg-sky-950/20 dark:shadow-[0_0_0_1px_rgba(125,211,252,0.16),0_10px_30px_rgba(14,165,233,0.16)]'
              : 'border-border/50 bg-card';
          const titleClass = friend.sponsored
            ? 'text-amber-200'
            : friend.referral
              ? 'text-sky-600 dark:text-sky-200'
              : 'text-primary';
          const descriptionClass = friend.sponsored
            ? 'text-zinc-300/80 dark:text-muted-foreground'
            : friend.referral
              ? 'text-muted-foreground'
              : 'text-muted-foreground';
          const iconClass = friend.sponsored
            ? 'text-zinc-300/70 hover:text-amber-200 dark:text-muted-foreground dark:hover:text-amber-200'
            : friend.referral
              ? 'text-muted-foreground hover:text-sky-600 dark:hover:text-sky-200'
              : 'text-muted-foreground hover:text-primary';
          const arrowClass = friend.sponsored
            ? 'text-zinc-300/40 hover:text-amber-200 dark:text-muted-foreground/50 dark:hover:text-amber-200'
            : friend.referral
              ? 'text-muted-foreground/50 hover:text-sky-600 dark:hover:text-sky-200'
              : 'text-muted-foreground/50 hover:text-primary';
          return (
          <div
            class={`group relative isolate flex min-h-[140px] flex-col justify-between overflow-hidden rounded-lg border p-5 transition-colors ${cardClass}`}
            data-friend-glow-card={friend.backgroundIcon ? true : undefined}
          >
            {friend.backgroundIcon && (
              <div class="friend-glow" aria-hidden="true">
                <img src={friend.backgroundIcon} alt="" loading="lazy" decoding="async" />
              </div>
            )}

            <a
              href={friend.url}
              target="_blank"
              rel={rel}
              class="absolute inset-0 z-10"
              aria-label={t('aria.friendSite').replace('{name}', friend.name)}
            />

            {/* Name */}
            <div class="relative z-20 pointer-events-none">
              <div class="mb-1.5 flex flex-wrap items-center gap-2">
                <h2 class={`friend-card-title text-base font-semibold ${titleClass}`}>{friend.name}</h2>
                {friend.pinned && (
                  <span class="rounded-md border border-border bg-background px-1.5 py-0.5 text-[10px] font-medium text-foreground">
                    {t('friends.pinned')}
                  </span>
                )}
                {friend.sponsored && (
                  <span class="rounded-md border border-amber-300/35 bg-amber-300/15 px-1.5 py-0.5 text-[10px] font-semibold text-amber-100 shadow-sm shadow-amber-500/10">
                    {t('friends.sponsored')}
                  </span>
                )}
                {friend.referral && (
                  <span class="rounded-md border border-sky-300/45 bg-sky-100/70 px-1.5 py-0.5 text-[10px] font-semibold text-sky-700 shadow-sm shadow-sky-500/10 dark:border-sky-300/35 dark:bg-sky-300/15 dark:text-sky-100">
                    {t('friends.referral')}
                  </span>
                )}
              </div>
              <p class={`text-sm leading-relaxed ${descriptionClass}`}>{friend.description}</p>
            </div>

            {/* Bottom row: sub-link icons left, arrow right */}
            <div class="relative z-20 flex items-center justify-between mt-4 pointer-events-none">
              <div class="flex items-center gap-2">
                {friend.links?.map(link => (
                  <a
                    href={link.url}
                    target="_blank"
                    rel={rel}
                    class={`relative z-30 pointer-events-auto transition-colors ${iconClass}`}
                    aria-label={t('aria.friendLink').replace('{name}', friend.name).replace('{type}', link.icon)}
                    title={link.icon}
                  >
                    <HugeIcon name={link.icon} className="size-4" size={16} />
                  </a>
                ))}
              </div>
              <span class={`transition-colors ${arrowClass}`} aria-hidden="true">
                <HugeIcon name="arrowRight" className="size-5" size={20} />
              </span>
            </div>
          </div>
        )})}
      </div>
    )}
  </div>
</Layout>

<style>
  /* Pointer glow adapted from Jhey Tompkins' CodePen: https://codepen.io/jh3y/pen/WbwZaNa */
  [data-friend-glow-card] {
    --friend-glow-x: 0;
    --friend-glow-y: 0;
  }

  .friend-card-title {
    display: inline;
    background-image: linear-gradient(currentColor, currentColor);
    background-position: 0 100%;
    background-repeat: no-repeat;
    background-size: 0 1px;
    box-decoration-break: clone;
    -webkit-box-decoration-break: clone;
    transition: background-size 180ms ease;
  }

  .group:is(:hover, :focus-within) .friend-card-title {
    background-size: 100% 1px;
  }

  .friend-glow {
    position: absolute;
    inset: -34%;
    z-index: 0;
    display: grid;
    place-items: center;
    pointer-events: none;
    opacity: 0.16;
    transform: translate(
      calc(var(--friend-glow-x) * 18%),
      calc(var(--friend-glow-y) * 18%)
    );
    transition:
      opacity 180ms ease,
      transform 220ms ease-out;
  }

  [data-friend-glow-card]:is(:hover, :focus-within) .friend-glow {
    opacity: 0.28;
  }

  .friend-glow img {
    width: min(46%, 9rem);
    aspect-ratio: 1;
    object-fit: contain;
    filter: blur(24px) saturate(1.8) brightness(1.12);
    opacity: 0.92;
    transform: scale(2.2);
  }

  @media (prefers-reduced-motion: reduce) {
    .friend-glow {
      transform: none;
      transition: opacity 180ms ease;
    }
  }
</style>

<script>
  (() => {
    interface FriendGlowController {
      init: () => void;
    }

    interface FriendGlowWindow extends Window {
      __lczFriendGlow?: FriendGlowController;
    }

    type FriendGlowPosition = {
      x: number;
      y: number;
    };

    const friendGlowWindow = window as FriendGlowWindow;
    const existing = friendGlowWindow.__lczFriendGlow;
    if (existing) {
      existing.init();
      return;
    }

    const motionQuery = window.matchMedia('(prefers-reduced-motion: reduce)');
    const clamp = (value: number, min: number, max: number) => Math.min(Math.max(value, min), max);
    const state = {
      boundCards: new WeakSet<HTMLElement>(),
      pending: new Map<HTMLElement, FriendGlowPosition>(),
      frame: 0,
    };

    const flush = () => {
      state.pending.forEach(({ x, y }, card) => {
        card.style.setProperty('--friend-glow-x', x.toFixed(3));
        card.style.setProperty('--friend-glow-y', y.toFixed(3));
      });
      state.pending.clear();
      state.frame = 0;
    };

    const schedule = (card: HTMLElement, x: number, y: number) => {
      state.pending.set(card, { x, y });
      if (state.frame === 0) {
        state.frame = window.requestAnimationFrame(flush);
      }
    };

    const bindCard = (card: HTMLElement) => {
      if (state.boundCards.has(card)) return;
      state.boundCards.add(card);

      card.addEventListener('pointermove', (event: PointerEvent) => {
        const rect = card.getBoundingClientRect();
        const x = (event.clientX - (rect.left + rect.width / 2)) / (rect.width / 2);
        const y = (event.clientY - (rect.top + rect.height / 2)) / (rect.height / 2);

        schedule(card, clamp(x, -1, 1), clamp(y, -1, 1));
      });

      card.addEventListener('pointerleave', () => {
        schedule(card, 0, 0);
      });
    };

    const init = () => {
      if (motionQuery.matches) return;
      document.querySelectorAll<HTMLElement>('[data-friend-glow-card]').forEach(bindCard);
    };

    document.addEventListener('astro:page-load', init);
    document.addEventListener('astro:after-swap', () => requestAnimationFrame(init));

    friendGlowWindow.__lczFriendGlow = { init };
    init();
  })();
</script>
