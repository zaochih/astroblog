---
import Layout from '@/layouts/Layout.astro';
import { siteConfig } from '@/config';
import { useTranslations, languages, defaultLang, type Lang } from '@/i18n/ui';
import yaml from 'js-yaml';
import friendsRaw from '@/data/friends.yaml?raw';

export async function getStaticPaths() {
  return Object.keys(languages).map(lang => ({
    params: { lang: lang === defaultLang ? undefined : lang },
    props: { lang },
  }));
}

const { lang } = Astro.props as { lang: string };
const t = useTranslations(lang as Lang);

interface FriendLink {
  icon: string;
  url: string;
}

interface Friend {
  name: string;
  description: string;
  url: string;
  links?: FriendLink[];
}

const friends = yaml.load(friendsRaw) as Friend[];

/**
 * Map icon name to inline SVG path data.
 * Uses Lucide icon paths (24×24 viewBox, stroke-based).
 */
const iconPaths: Record<string, string> = {
  home: '<path d="M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8"/><path d="M3 10a2 2 0 0 1 .709-1.528l7-5.999a2 2 0 0 1 2.582 0l7 5.999A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>',
  image: '<rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>',
  globe: '<circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/>',
  link: '<path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>',
  rss: '<path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/>',
  github: '<path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/>',
  mail: '<rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>',
  pen: '<path d="M21.174 6.812a1 1 0 0 0-3.986-3.987L3.842 16.174a2 2 0 0 0-.5.83l-1.321 4.352a.5.5 0 0 0 .623.622l4.353-1.32a2 2 0 0 0 .83-.497z"/>',
};

function getIconSvg(name: string): string {
  const paths = iconPaths[name] ?? iconPaths.link;
  return `<svg xmlns="http://www.w3.org/2000/svg" class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${paths}</svg>`;
}
---

<Layout title={`${t('friends.title')} | ${siteConfig.name}`} lang={lang}>
  <div class="max-w-4xl mx-auto">
    <h1 class="text-3xl font-bold tracking-tight text-foreground mb-8">{t('friends.title')}</h1>

    {friends.length === 0 ? (
      <div class="text-center py-20 text-muted-foreground border border-dashed border-border/60 rounded-md">
        {t('friends.empty')}
      </div>
    ) : (
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {friends.map(friend => (
          <div class="group relative flex flex-col justify-between rounded-lg border border-border/50 bg-card p-5 min-h-[140px]">
            {/* Name */}
            <div>
              <h2 class="text-base font-semibold text-primary mb-1.5">{friend.name}</h2>
              <p class="text-sm text-muted-foreground leading-relaxed">{friend.description}</p>
            </div>

            {/* Bottom row: sub-link icons left, arrow right */}
            <div class="flex items-center justify-between mt-4">
              <div class="flex items-center gap-2">
                {friend.links?.map(link => (
                  <a
                    href={link.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="relative z-10 text-muted-foreground hover:text-primary transition-colors"
                    title={link.icon}
                  >
                    <Fragment set:html={getIconSvg(link.icon)} />
                  </a>
                ))}
              </div>
              <a
                href={friend.url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-muted-foreground/50 hover:text-primary transition-colors after:absolute after:inset-0 after:content-['']"
                aria-label={`Visit ${friend.name}`}
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
              </a>
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</Layout>
