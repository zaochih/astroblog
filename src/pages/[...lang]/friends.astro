---
import Layout from '@/layouts/Layout.astro';
import { siteConfig } from '@/config';
import { useTranslations, languages, defaultLang, type Lang } from '@/i18n/ui';
import yaml from 'js-yaml';
import friendsRaw from '@/data/friends.yaml?raw';
import HugeIcon from '@/components/HugeIcon';

export async function getStaticPaths() {
  return Object.keys(languages).map(lang => ({
    params: { lang: lang === defaultLang ? undefined : lang },
    props: { lang },
  }));
}

const { lang } = Astro.props as { lang: string };
const t = useTranslations(lang as Lang);

interface FriendLink {
  icon: string;
  url: string;
}

interface Friend {
  name: string;
  description: string;
  url: string;
  links?: FriendLink[];
}

const friends = yaml.load(friendsRaw) as Friend[];
---

<Layout title={`${t('friends.title')} | ${siteConfig.name}`} lang={lang}>
  <div class="max-w-4xl mx-auto">
    <h1 class="text-3xl font-bold tracking-tight text-foreground mb-8">{t('friends.title')}</h1>

    {friends.length === 0 ? (
      <div class="text-center py-20 text-muted-foreground border border-dashed border-border/60 rounded-md">
        {t('friends.empty')}
      </div>
    ) : (
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {friends.map(friend => (
          <div class="group relative flex flex-col justify-between rounded-lg border border-border/50 bg-card p-5 min-h-[140px]">
            {/* Name */}
            <div>
              <h2 class="text-base font-semibold text-primary mb-1.5">{friend.name}</h2>
              <p class="text-sm text-muted-foreground leading-relaxed">{friend.description}</p>
            </div>

            {/* Bottom row: sub-link icons left, arrow right */}
            <div class="flex items-center justify-between mt-4">
              <div class="flex items-center gap-2">
                {friend.links?.map(link => (
                  <a
                    href={link.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="relative z-10 text-muted-foreground hover:text-primary transition-colors"
                    title={link.icon}
                  >
                    <HugeIcon name={link.icon} className="size-4" size={16} />
                  </a>
                ))}
              </div>
              <a
                href={friend.url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-muted-foreground/50 hover:text-primary transition-colors after:absolute after:inset-0 after:content-['']"
                aria-label={`Visit ${friend.name}`}
              >
                <HugeIcon name="arrowRight" className="size-5" size={20} />
              </a>
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</Layout>
