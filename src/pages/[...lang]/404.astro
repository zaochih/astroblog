---
import Layout from '@/layouts/Layout.astro';
import { siteConfig } from '@/config';
import { languages, defaultLang, type Lang } from '@/i18n/ui';

export async function getStaticPaths() {
  return Object.keys(languages).map((l) => ({
    params: { lang: l === defaultLang ? undefined : l },
    props: { lang: l as Lang },
  }));
}

interface Props { lang: Lang; }

const { lang } = Astro.props;
const isEn = lang === 'en-us';
const homeHref = isEn ? '/en-us/' : '/';

const btnBase = "inline-flex shrink-0 items-center justify-center gap-1 rounded-md border border-transparent bg-clip-padding text-sm font-medium whitespace-nowrap transition-all outline-none select-none focus-visible:border-ring focus-visible:ring-2 focus-visible:ring-ring/30 active:translate-y-px h-11 px-6";
const btnPrimary = `${btnBase} bg-primary text-primary-foreground hover:bg-primary/80`;
const btnOutline = `${btnBase} border-border hover:bg-input/50 hover:text-foreground dark:bg-input/30`;
---

<Layout title={`404 — ${siteConfig.name}`} lang={lang}>
  <div class="flex flex-col items-center justify-center min-h-[calc(100vh-14rem)] text-center px-4">

    <p class="text-[clamp(10rem,35vw,22rem)] font-black tracking-tight leading-none text-muted-foreground/15 select-none mb-6">404</p>

    <h1 class="text-xl font-semibold text-foreground mb-2">
      {isEn ? "You've wandered into the wasteland…" : '你似乎来到了没有内容的荒原……'}
    </h1>
    <p class="text-sm text-muted-foreground mb-10 max-w-sm leading-relaxed">
      {isEn
        ? 'Please check the link or contact whoever shared it with you.'
        : '请联系链接提供者以确认此链接的有效性。'}
    </p>

    <div class="flex items-center gap-3">
      <a href={homeHref} class={btnPrimary}>
        {isEn ? 'Back to Home' : '返回首页'}
      </a>
      <button onclick="history.back()" class={btnOutline}>
        {isEn ? 'Go Back' : '返回上一页'}
      </button>
    </div>

  </div>
</Layout>
