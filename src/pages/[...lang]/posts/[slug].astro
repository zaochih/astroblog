---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import { buttonVariants } from '@/components/ui/button';
import { siteConfig } from '@/config';
import { useTranslations, languages, languageNames, defaultLang, type Lang } from '@/i18n/ui';
import { getCategoryHref, countWords, readingMinutes, formatDateTime, mergeWithPrimary } from '@/lib/content';
import { getCategoryName } from '@/i18n/taxonomy';

export async function getStaticPaths() {
  // Helper: "zh/hello-world" → ["zh", "hello-world"]
  function parseEntryId(id: string) {
    const [lang, ...rest] = id.split('/');
    return { lang, slug: rest.join('/') };
  }

  const allPosts = await getCollection('blog');
  const locales = Object.keys(languages) as Lang[];

  // Group posts by slug across languages
  const postsBySlug = new Map<string, Record<string, CollectionEntry<'blog'>>>();
  for (const post of allPosts) {
    const { lang, slug } = parseEntryId(post.id);
    if (!postsBySlug.has(slug)) postsBySlug.set(slug, {});
    postsBySlug.get(slug)![lang] = post;
  }

  const paths: {
    params: { lang: string | undefined; slug: string };
    props: Props;
  }[] = [];

  for (const [slug, langsMap] of postsBySlug) {
    for (const lang of locales) {
      const post = langsMap[lang];
      const fallbackPost = langsMap[defaultLang];
      const availableLangs = Object.keys(langsMap);
      const otherLangs = availableLangs.filter(l => l !== lang);
      const routeLang = lang === defaultLang ? undefined : lang;

      if (post) {
        paths.push({
          params: { lang: routeLang, slug },
          props: {
            post, slug, isFallback: false, currentLang: lang, fallbackLang: null, otherLangs,
            primaryData: lang !== defaultLang ? langsMap[defaultLang]?.data : undefined,
          },
        });
      } else if (fallbackPost) {
        paths.push({
          params: { lang: routeLang, slug },
          props: {
            post: fallbackPost, slug, isFallback: true, currentLang: lang, fallbackLang: defaultLang, otherLangs: availableLangs,
            primaryData: undefined,
          },
        });
      }
    }
  }

  return paths;
}

interface Props {
  post: CollectionEntry<'blog'>;
  slug: string;
  isFallback: boolean;
  currentLang: Lang;
  fallbackLang: Lang | null;
  otherLangs: string[];
  primaryData?: CollectionEntry<'blog'>['data'];
}

const { post, slug, isFallback, currentLang, fallbackLang, otherLangs, primaryData } = Astro.props;
const data = mergeWithPrimary(post.data, primaryData);
const { Content, headings } = await render(post);

const t = useTranslations(currentLang);
const wordCount = countWords(post.body ?? '');
const minutes = readingMinutes(wordCount);
const hasToc = headings.filter(h => h.depth <= 3).length > 2;

const fallbackLangName = isFallback && fallbackLang ? languageNames[currentLang][fallbackLang] : '';
const fallbackDesc = t('alert.fallback.desc').replace('{lang}', fallbackLangName);

const getLangLink = (l: string) =>
  l === defaultLang ? `/posts/${slug}` : `/${l}/posts/${slug}`;

const homeHref = currentLang === defaultLang ? '/' : `/${currentLang}/`;
---

<Layout title={`${post.data.title} | ${siteConfig.name}`} description={post.data.description} lang={currentLang}>
  <div class={hasToc ? "max-w-5xl mx-auto mt-10 xl:grid xl:grid-cols-[1fr_220px] xl:gap-10 xl:items-start" : "max-w-3xl mx-auto mt-10"}>
  <article transition:name={`post-${slug}`} class="min-w-0">

    <a href={homeHref} class={`${buttonVariants({ variant: "ghost" })} mb-6 hover:bg-accent/50 -ml-4`}>
      {t('post.back')}
    </a>

    <header class="mb-8 text-center">
      <h1 class="text-4xl font-extrabold tracking-tight text-foreground mb-4 leading-tight">
        {post.data.title}
      </h1>
      <div class="flex flex-wrap items-center justify-center gap-x-4 gap-y-1 text-xs text-muted-foreground">
        {data.date && (
          <span class="inline-flex items-center gap-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="size-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
            <time datetime={data.date.toISOString()}>{formatDateTime(data.date, currentLang)}</time>
          </span>
        )}
        {data.category && (
          <a href={getCategoryHref(data.category, currentLang)} class="inline-flex items-center gap-1 hover:text-primary transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="size-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 20a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.69-.9L9.6 3.9A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z"/></svg>
            {getCategoryName(data.category, currentLang)}
          </a>
        )}
        <span class="inline-flex items-center gap-1">
          <svg xmlns="http://www.w3.org/2000/svg" class="size-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
          {t('post.wordCount').replace('{count}', String(wordCount))}
        </span>
        <span class="inline-flex items-center gap-1">
          <svg xmlns="http://www.w3.org/2000/svg" class="size-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          {t('post.readingTime').replace('{min}', String(minutes))}
        </span>
      </div>
    </header>

    {isFallback && (
      <div role="alert" class="mb-8 flex gap-3 rounded-lg border border-destructive/50 bg-destructive/10 p-4 text-destructive text-sm">
        <svg xmlns="http://www.w3.org/2000/svg" class="size-4 shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3"/><line x1="12" x2="12" y1="9" y2="13"/><line x1="12" x2="12.01" y1="17" y2="17"/></svg>
        <div>
          <p class="font-semibold">{t('alert.fallback.title')}</p>
          <p class="mt-1">{fallbackDesc}</p>
        </div>
      </div>
    )}

    {!isFallback && otherLangs.length > 0 && (
      <div class="mb-8 flex items-center gap-2 rounded-lg border border-primary/30 bg-primary/5 p-4 text-sm text-foreground shadow-fluent-sm">
        <svg xmlns="http://www.w3.org/2000/svg" class="size-4 shrink-0 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="16" y2="12"/><line x1="12" x2="12.01" y1="8" y2="8"/></svg>
        <span>{t('alert.available')}</span>
        {otherLangs.map(l => (
          <a href={getLangLink(l)} class="text-primary font-medium hover:underline">
            [{languages[l as Lang]}]
          </a>
        ))}
      </div>
    )}

    <div class="prose dark:prose-invert max-w-none prose-a:text-primary prose-a:no-underline hover:prose-a:underline">
      <Content />
    </div>

  </article>

  {hasToc && (
    <aside class="hidden xl:block sticky top-24 self-start">
      <div class="rounded-lg border border-border/50 bg-card p-4">
        <p class="text-xs font-semibold text-foreground/70 uppercase tracking-wider mb-3">
          {t('post.toc')}
        </p>
        <nav>
          <ul class="space-y-1.5">
            {headings.filter(h => h.depth <= 3).map(h => (
              <li>
                <a
                  href={`#${h.slug}`}
                  class={`block text-xs text-muted-foreground hover:text-primary transition-colors leading-relaxed ${h.depth >= 3 ? 'pl-3' : ''}`}
                >
                  {h.text}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>
    </aside>
  )}

  </div>
</Layout>
