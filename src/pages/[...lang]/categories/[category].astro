---
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import { siteConfig } from '@/config';
import { useTranslations, defaultLang, getSupportedLangs, type Lang } from '@/i18n/ui';
import { localizeAndSortPosts, isPublishedEntry } from '@/lib/content';
import { getCategoryName, getCategoryPathSegment, resolveCategoryKey } from '@/i18n/taxonomy';
import TaxonomyPostList from '@/components/TaxonomyPostList.astro';
import { describeListingPage } from '@/lib/seo';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  const locales = getSupportedLangs();

  return locales.flatMap(lang => {
    const allCategories = [...new Set(localizeAndSortPosts(allPosts, lang, { includeFallback: false })
      .filter(({ post }) => isPublishedEntry(post))
      .map(({ post }) => post.data.category)
      .filter((c): c is string => !!c)
      .map(resolveCategoryKey))];

    return allCategories.map(category => ({
      params: { lang: lang === defaultLang ? undefined : lang, category: getCategoryPathSegment(category, lang) },
      props: { lang, category },
    }));
  });
}

const { lang, category } = Astro.props as { lang: string; category: string };
const t = useTranslations(lang as Lang);

const allPosts = await getCollection('blog');
const localizedPosts = localizeAndSortPosts(allPosts, lang, { includeFallback: false })
  .filter(({ post }) => post.data.category && resolveCategoryKey(post.data.category) === category);

const categoryName = getCategoryName(category, lang as Lang);
const pageHeading = t('category.title').replace('{category}', categoryName);
---

<Layout
  title={`${pageHeading} | ${siteConfig.name}`}
  description={describeListingPage({ kind: 'category', lang, label: categoryName })}
  lang={lang}
>
  <div class="max-w-2xl mx-auto">
    <h1 class="text-3xl font-bold tracking-tight text-foreground mb-2">{pageHeading}</h1>
    <p class="text-sm text-muted-foreground mb-8">
      {t('listing.postCount').replace('{count}', String(localizedPosts.length))}
    </p>

    {localizedPosts.length === 0 ? (
      <div class="text-center py-20 text-muted-foreground border border-dashed border-border/60 rounded-md">
        {t('listing.empty')}
      </div>
    ) : (
      <TaxonomyPostList posts={localizedPosts} lang={lang} />
    )}
  </div>
</Layout>
