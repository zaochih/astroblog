---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import { siteConfig } from '@/config';
import { useTranslations, languages, languageNames, defaultLang, type Lang } from '@/i18n/ui';
import { isPublishedEntry } from '@/lib/content';
import LanguageNotice from '@/components/LanguageNotice.astro';

export async function getStaticPaths() {
  function parseEntryId(id: string) {
    const [lang, ...rest] = id.split('/');
    return { lang, slug: rest.join('/') };
  }

  const allPages = (await getCollection('pages')).filter(isPublishedEntry);
  const locales = Object.keys(languages) as Lang[];

  const pagesBySlug = new Map<string, Record<string, CollectionEntry<'pages'>>>();
  for (const page of allPages) {
    const { lang, slug } = parseEntryId(page.id);
    if (!pagesBySlug.has(slug)) pagesBySlug.set(slug, {});
    pagesBySlug.get(slug)![lang] = page;
  }

  const paths: {
    params: { lang: string | undefined; slug: string };
    props: Props;
  }[] = [];

  for (const [slug, langsMap] of pagesBySlug) {
    for (const lang of locales) {
      const page = langsMap[lang];
      const fallbackPage = langsMap[defaultLang];
      const availableLangs = Object.keys(langsMap);
      const otherLangs = availableLangs.filter(l => l !== lang);
      const routeLang = lang === defaultLang ? undefined : lang;

      if (page) {
        paths.push({
          params: { lang: routeLang, slug },
          props: { page, slug, isFallback: false, currentLang: lang, fallbackLang: null, otherLangs },
        });
      } else if (fallbackPage) {
        paths.push({
          params: { lang: routeLang, slug },
          props: { page: fallbackPage, slug, isFallback: true, currentLang: lang, fallbackLang: defaultLang, otherLangs: availableLangs },
        });
      }
    }
  }

  return paths;
}

interface Props {
  page: CollectionEntry<'pages'>;
  slug: string;
  isFallback: boolean;
  currentLang: Lang;
  fallbackLang: Lang | null;
  otherLangs: string[];
}

const { page, slug, isFallback, currentLang, fallbackLang, otherLangs } = Astro.props;
const { Content } = await render(page);

const t = useTranslations(currentLang);

const fallbackLangName = isFallback && fallbackLang ? languageNames[currentLang][fallbackLang] : '';
const fallbackDesc = t('page.fallback.desc').replace('{lang}', fallbackLangName);

const getLangLink = (l: string) =>
  l === defaultLang ? `/${slug}` : `/${l}/${slug}`;
const otherLanguageLinks = otherLangs.map(l => ({
  href: getLangLink(l),
  label: languages[l as Lang],
  lang: l,
  ariaLabel: t('aria.switchLanguage').replace('{lang}', languageNames[currentLang][l as Lang]),
}));
---

<Layout
  title={`${page.data.title} | ${siteConfig.name}`}
  description={page.data.description}
  lang={currentLang}
>
  <article class="max-w-3xl mx-auto mt-10">

    <header class="mb-6">
      <h1 class="text-4xl font-extrabold tracking-tight text-foreground leading-tight">
        {page.data.title}
      </h1>
    </header>

    {isFallback && (
      <LanguageNotice type="fallback" title={t('alert.fallback.title')} message={fallbackDesc} />
    )}

    {!isFallback && otherLangs.length > 0 && (
      <LanguageNotice type="available" availableLabel={t('page.available')} languages={otherLanguageLinks} />
    )}

    <div class="prose dark:prose-invert max-w-none prose-a:text-primary prose-a:no-underline hover:prose-a:underline">
      <Content />
    </div>

  </article>
</Layout>
