---
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import { siteConfig } from '@/config';
import { useTranslations, languages, defaultLang, type Lang } from '@/i18n/ui';
import { localizeAndSortPosts, isPublishedEntry } from '@/lib/content';
import { getTagName, getTagPathSegment, resolveTagKey } from '@/i18n/taxonomy';
import TaxonomyPostList from '@/components/TaxonomyPostList.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  const locales = Object.keys(languages) as Lang[];
  const allTags = [...new Set(allPosts.filter(isPublishedEntry).flatMap(p => p.data.tags ?? []).map(resolveTagKey))];

  return locales.flatMap(lang =>
    allTags.map(tag => ({
      params: { lang: lang === defaultLang ? undefined : lang, tag: getTagPathSegment(tag, lang) },
      props: { lang, tag },
    })),
  );
}

const { lang, tag } = Astro.props as { lang: string; tag: string };
const t = useTranslations(lang as Lang);

const allPosts = await getCollection('blog');
const localizedPosts = localizeAndSortPosts(allPosts, lang)
  .filter(({ post }) => post.data.tags?.some(postTag => resolveTagKey(postTag) === tag));

const pageHeading = t('tag.title').replace('{tag}', getTagName(tag, lang as Lang));
---

<Layout
  title={`${pageHeading} | ${siteConfig.name}`}
  lang={lang}
>
  <div class="max-w-2xl mx-auto">
    <h1 class="text-3xl font-bold tracking-tight text-foreground mb-2">{pageHeading}</h1>
    <p class="text-sm text-muted-foreground mb-8">
      {t('listing.postCount').replace('{count}', String(localizedPosts.length))}
    </p>

    {localizedPosts.length === 0 ? (
      <div class="text-center py-20 text-muted-foreground border border-dashed border-border/60 rounded-md">
        {t('listing.empty')}
      </div>
    ) : (
      <TaxonomyPostList posts={localizedPosts} lang={lang} />
    )}
  </div>
</Layout>
