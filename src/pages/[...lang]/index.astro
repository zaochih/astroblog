---
import Layout from '@/layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { siteConfig } from '@/config';
import { useTranslations, languages, defaultLang, type Lang } from '@/i18n/ui';
import { localizeAndSortPosts } from '@/lib/content';
import PostFeed from '@/components/PostFeed.astro';
import BlogSidebar from '@/components/BlogSidebar.astro';

export async function getStaticPaths() {
  return Object.keys(languages).map(lang => ({
    params: { lang: lang === defaultLang ? undefined : lang },
    props: { lang },
  }));
}

const { lang } = Astro.props as { lang: string };
const t = useTranslations(lang as Lang);

const allPosts = await getCollection('blog');
const localizedPosts = localizeAndSortPosts(allPosts, lang);

const PAGE_SIZE = 10;
const totalPages = Math.max(1, Math.ceil(localizedPosts.length / PAGE_SIZE));
const page1Posts = localizedPosts.slice(0, PAGE_SIZE);
const baseHref = lang === defaultLang ? '/' : `/${lang}/`;

---

<Layout title={`${t('nav.home')} | ${siteConfig.name}`} lang={lang} showLangToast>
  <div class="lg:grid lg:grid-cols-[220px_1fr_220px] lg:gap-8">

    <BlogSidebar posts={localizedPosts} lang={lang} side="left" />

    {/* Center — post feed */}
    <div>
      {localizedPosts.length === 0 ? (
        <div class="text-center py-20 text-muted-foreground border border-dashed border-border/60 rounded-md">
          {t('home.empty')}
        </div>
      ) : (
        <PostFeed
          posts={page1Posts}
          lang={lang}
          currentPage={1}
          totalPages={totalPages}
          baseHref={baseHref}
        />
      )}
    </div>

    <BlogSidebar posts={localizedPosts} lang={lang} side="right" />

  </div>
</Layout>
