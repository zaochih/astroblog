---
import Layout from '@/layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { siteConfig } from '@/config';
import { useTranslations, languages, defaultLang, type Lang } from '@/i18n/ui';
import { localizeAndSortPosts, getTagHref, getCategoryHref, countWords, formatWordCount } from '@/lib/content';
import { getTagName, getCategoryName } from '@/i18n/taxonomy';
import PostFeed from '@/components/PostFeed.astro';

export async function getStaticPaths() {
  return Object.keys(languages).map(lang => ({
    params: { lang: lang === defaultLang ? undefined : lang },
    props: { lang },
  }));
}

const { lang } = Astro.props as { lang: string };
const t = useTranslations(lang as Lang);

const allPosts = await getCollection('blog');
const localizedPosts = localizeAndSortPosts(allPosts, lang);

const PAGE_SIZE = 10;
const totalPages = Math.max(1, Math.ceil(localizedPosts.length / PAGE_SIZE));
const page1Posts = localizedPosts.slice(0, PAGE_SIZE);
const baseHref = lang === defaultLang ? '/' : `/${lang}/`;

const bio = siteConfig.author.bio[lang as keyof typeof siteConfig.author.bio] ?? siteConfig.author.bio[siteConfig.defaultLang];

// Collect tags/categories only from the current-lang post list
const allTags = [...new Set(localizedPosts.flatMap(({ post }) => post.data.tags ?? []))].sort();
const allCategories = [...new Set(localizedPosts.map(({ post }) => post.data.category).filter(Boolean))].sort();

// Stats
const totalWords = localizedPosts.reduce((sum, { post }) => sum + countWords(post.body ?? ''), 0);
const totalWordsFormatted = formatWordCount(totalWords, lang);
---

<Layout title={`${t('nav.home')} | ${siteConfig.name}`} lang={lang} showLangToast>
  <div class="lg:grid lg:grid-cols-[220px_1fr_220px] lg:gap-8">

    {/* Left sidebar — author info */}
    <aside class="hidden lg:block sticky top-20 self-start space-y-4">
      <div class="flex flex-col items-center gap-3 rounded-lg border border-border/50 bg-card p-5">
        <img
          src={siteConfig.author.avatar}
          alt={siteConfig.author.name}
          class="size-20 rounded-full border-2 border-primary/20 object-cover"
        />
        <h2 class="text-sm font-semibold text-foreground">{siteConfig.author.name}</h2>
        <p class="text-xs text-muted-foreground text-center leading-relaxed">{bio}</p>
        <div class="flex items-center gap-3">
          {siteConfig.author.links.github && (
            <a
              href={siteConfig.author.links.github}
              target="_blank"
              rel="noopener noreferrer me"
              class="text-muted-foreground hover:text-primary transition-colors"
              title="GitHub"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="size-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
            </a>
          )}
          {siteConfig.author.links.twitter && (
            <a
              href={`https://x.com/${siteConfig.author.links.twitter}`}
              target="_blank"
              rel="noopener noreferrer me"
              class="text-muted-foreground hover:text-primary transition-colors"
              title="X / Twitter"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="size-4" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
          )}
        </div>
      </div>

      {/* Stats */}
      <div class="grid grid-cols-2 gap-px rounded-lg border border-border/50 bg-border/50 overflow-hidden">
        <div class="flex flex-col items-center py-3 bg-card">
          <span class="text-base font-bold text-foreground">{localizedPosts.length}</span>
          <span class="text-[10px] text-muted-foreground">{t('stats.posts')}</span>
        </div>
        <div class="flex flex-col items-center py-3 bg-card">
          <span class="text-base font-bold text-foreground">{allCategories.length}</span>
          <span class="text-[10px] text-muted-foreground">{t('stats.categories')}</span>
        </div>
        <div class="flex flex-col items-center py-3 bg-card">
          <span class="text-base font-bold text-foreground">{allTags.length}</span>
          <span class="text-[10px] text-muted-foreground">{t('stats.tags')}</span>
        </div>
        <div class="flex flex-col items-center py-3 bg-card">
          <span class="text-base font-bold text-foreground">{totalWordsFormatted.split(' ')[0]}</span>
          <span class="text-[10px] text-muted-foreground">{totalWordsFormatted.split(' ').slice(1).join(' ')}</span>
        </div>
      </div>
    </aside>

    {/* Center — post feed */}
    <div>
      {localizedPosts.length === 0 ? (
        <div class="text-center py-20 text-muted-foreground border border-dashed border-border/60 rounded-md">
          {t('home.empty')}
        </div>
      ) : (
        <PostFeed
          posts={page1Posts}
          lang={lang}
          currentPage={1}
          totalPages={totalPages}
          baseHref={baseHref}
        />
      )}
    </div>

    {/* Right sidebar — tags & categories */}
    <aside class="hidden lg:block sticky top-20 self-start space-y-6">
      {allCategories.length > 0 && (
        <div class="rounded-lg border border-border/50 bg-card p-5">
          <h3 class="text-xs font-semibold text-foreground uppercase tracking-wider mb-3">{t('sidebar.categories')}</h3>
          <div class="flex flex-col gap-1.5">
            {allCategories.map(cat => (
              <a
                href={getCategoryHref(cat!, lang)}
                class="text-xs text-muted-foreground hover:text-primary transition-colors"
              >
                {getCategoryName(cat!, lang as Lang)}
              </a>
            ))}
          </div>
        </div>
      )}

      {allTags.length > 0 && (
        <div class="rounded-lg border border-border/50 bg-card p-5">
          <h3 class="text-xs font-semibold text-foreground uppercase tracking-wider mb-3">{t('sidebar.tags')}</h3>
          <div class="flex flex-wrap gap-1.5">
            {allTags.map(tag => (
              <a
                href={getTagHref(tag, lang)}
                class="text-xs px-2 py-0.5 rounded-md bg-muted text-muted-foreground hover:bg-primary/10 hover:text-primary transition-colors"
              >
                #{getTagName(tag, lang as Lang)}
              </a>
            ))}
          </div>
        </div>
      )}
    </aside>

  </div>
</Layout>
